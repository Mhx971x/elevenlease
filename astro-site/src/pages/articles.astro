---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = (await getCollection('articles')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const categories = [...new Set(entries.map(e => e.data.category))];

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Articles — Eleven Lease',
  url: 'https://elevenlease.fr/articles',
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: entries.map((e, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://elevenlease.fr/articles/${e.id}`,
      name: e.data.title,
    })),
  },
};
---
<BaseLayout
  title="Articles — Guide leasing et LOA | Eleven Lease"
  description="Conseils, guides et actualités sur le leasing automobile (LOA/LLD) : financement, profils spécifiques, fonctionnement des contrats. Par l'équipe Eleven Lease."
  path="/articles"
  active="articles"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
  </Fragment>

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow"><span class="dot"></span> Mis à jour régulièrement</div>
      <h1>Le leasing expliqué, sans jargon.</h1>
      <p>Guides, conseils de financement et cas particuliers : tout ce qu'il faut savoir avant de signer une LOA ou une LLD, par l'équipe Eleven Lease.</p>
    </div>
  </section>

  <section class="articles-section">
    <div class="wrap">
      <div class="cat-tabs" id="catTabs">
        <button type="button" class="cat-tab active" data-cat="all">Tous</button>
        {categories.map(c => <button type="button" class="cat-tab" data-cat={c}>{c}</button>)}
      </div>

      <div class="articles-grid" id="articlesGrid">
        {entries.map(e => (
          <a class="article-card" href={`/articles/${e.id}`} data-cat={e.data.category}>
            <div class="article-cat">{e.data.category}</div>
            <h2>{e.data.title}</h2>
            <p>{e.data.description}</p>
            <div class="article-foot">
              <span class="article-meta">{e.data.readTime} de lecture</span>
              <span class="article-link">Lire →</span>
            </div>
          </a>
        ))}
      </div>

      {entries.length === 0 && (
        <div class="empty-state">
          <h3>Premiers articles à venir</h3>
          <p>Nous préparons nos premiers guides sur le leasing automobile.</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<script>
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('.cat-tab'));
  const cards = Array.from(document.querySelectorAll<HTMLAnchorElement>('.article-card'));

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');
      const cat = tab.dataset.cat;
      cards.forEach(card => {
        card.style.display = (cat === 'all' || card.dataset.cat === cat) ? '' : 'none';
      });
    });
  });
</script>

<style>
  .page-hero{padding:150px 0 40px;border-bottom:1px solid var(--border);background:var(--surface);}
  .page-hero .eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--text-dim);border:1px solid var(--border);padding:6px 14px;border-radius:100px;margin-bottom:24px;width:fit-content;}
  .page-hero .eyebrow .dot{width:6px;height:6px;border-radius:50%;background:var(--accent-1);}
  .page-hero h1{font-size:clamp(32px,5vw,52px);max-width:700px;}
  .page-hero p{color:var(--text-dim);font-size:16px;margin-top:14px;max-width:560px;}

  .articles-section{padding:48px 0 96px;}

  .cat-tabs{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:36px;}
  .cat-tab{
    background:none;border:1px solid var(--border);color:var(--text-dim);
    padding:9px 18px;border-radius:100px;font-size:13.5px;font-family:'Inter',sans-serif;cursor:pointer;
    transition:border-color .2s ease, color .2s ease, background .2s ease;
  }
  .cat-tab:hover{border-color:#d8d8dd;color:var(--text);}
  .cat-tab.active{background:var(--accent);border-color:transparent;color:#fff;}

  .articles-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
  @media(max-width:980px){ .articles-grid{grid-template-columns:repeat(2,1fr);} }
  @media(max-width:640px){ .articles-grid{grid-template-columns:1fr;} }

  .article-card{
    display:flex;flex-direction:column;
    background:#fff;border:1px solid var(--border);border-radius:20px;
    padding:28px;box-shadow:var(--shadow-sm);
    transition:transform .3s cubic-bezier(.16,1,.3,1), border-color .3s ease, box-shadow .3s ease;
  }
  .article-card:hover{transform:translateY(-4px);border-color:#d8d8dd;box-shadow:var(--shadow-md);}
  .article-cat{font-size:12px;color:var(--accent-1);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:14px;}
  .article-card h2{font-size:19px;line-height:1.3;margin-bottom:10px;}
  .article-card p{color:var(--text-dim);font-size:14px;line-height:1.6;flex:1;}
  .article-foot{display:flex;justify-content:space-between;align-items:center;margin-top:20px;padding-top:16px;border-top:1px solid var(--border);}
  .article-meta{font-size:12.5px;color:var(--text-faint);}
  .article-link{font-size:13.5px;font-weight:600;color:var(--text);transition:gap .2s ease;}
  .article-card:hover .article-link{color:var(--accent-1);}

  .empty-state{text-align:center;padding:64px 24px;color:var(--text-dim);}
  .empty-state h3{color:var(--text);font-size:20px;margin-bottom:10px;}
</style>
