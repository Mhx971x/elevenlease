---
import MinimalLayout from '../layouts/MinimalLayout.astro';
---
<MinimalLayout
  title="Eleven Lease — Simulez votre leasing"
  description="Simulez votre leasing en 2 minutes : décrivez votre projet, notre réseau de partenaires vous trouve la meilleure offre LOA/LLD sous 24h."
  path="/simulation"
>

<header>
  <nav>
    <a href="/" class="logo">
      <span class="logo-icon" role="img" aria-label="Eleven Lease"></span>
    </a>
    <a href="/" class="back-link">← Retour à l'accueil</a>
  </nav>
</header>

<section class="simulation-screen">
  <div class="wrap">
    <div class="contact-panel">
      <div class="contact-intro" id="contactIntro">
        <h1>Obtenez votre offre de leasing en moins de 2 minutes.</h1>
        <div class="trust-badges">
          <span class="trust-badge">✓ Sans engagement</span>
          <span class="trust-badge">✓ Réponse sous 24h</span>
          <span class="trust-badge">✓ Réseau de partenaires spécialisés</span>
        </div>
        <p>Quelques questions rapides pour une offre sur-mesure de notre réseau de partenaires, sans engagement.</p>
      </div>
      <form id="leadForm" class="lead-form" novalidate>
        <div class="stepper-progress" id="stepperProgress">
          <div class="stepper-bar-track"><div class="stepper-bar-fill" id="stepperBarFill"></div></div>
          <div class="stepper-meta">
            <div class="stepper-label" id="stepperLabel">Question 1 / 17</div>
            <div class="stepper-time" id="stepperTime">~2 min restantes</div>
          </div>
        </div>

        <div class="form-step active" data-step="1">
          <label for="fVehicule"><span class="step-icon" aria-hidden="true">🚗</span>Quel véhicule vous intéresse ?</label>
          <input type="text" id="fVehicule" name="vehicule" placeholder="Ex : Renault Clio (laissez vide si vous hésitez)">
        </div>

        <div class="form-step" data-step="2">
          <label><span class="step-icon" aria-hidden="true">👤</span>Ce financement est-il à titre personnel ou professionnel ?</label>
          <div class="radio-group">
            <label class="radio-option"><input type="radio" name="profil" value="Particulier" checked> Particulier</label>
            <label class="radio-option"><input type="radio" name="profil" value="Professionnel"> Professionnel</label>
          </div>
        </div>

        <div class="form-step" data-step="3">
          <label><span class="step-icon" aria-hidden="true">💳</span>Quel type de financement souhaitez-vous ?</label>
          <div class="choice-grid">
            <label class="radio-option"><input type="radio" name="financement" value="Leasing (LOA/LLD)" checked> Leasing (LOA/LLD)</label>
            <label class="radio-option"><input type="radio" name="financement" value="Achat"> Achat</label>
            <label class="radio-option"><input type="radio" name="financement" value="Je ne sais pas encore"> Je ne sais pas encore</label>
          </div>
        </div>

        <div class="form-step" data-step="4">
          <label><span class="step-icon" aria-hidden="true">🚘</span>Vos préférences véhicule</label>
          <div class="field-stack">
            <div class="field-item">
              <label><span class="step-icon" aria-hidden="true">🚙</span>Type de véhicule souhaité</label>
              <div class="choice-grid">
                <label class="radio-option"><input type="radio" name="typeVehicule" value="Citadine"> Citadine</label>
                <label class="radio-option"><input type="radio" name="typeVehicule" value="Berline"> Berline</label>
                <label class="radio-option"><input type="radio" name="typeVehicule" value="SUV"> SUV</label>
                <label class="radio-option"><input type="radio" name="typeVehicule" value="Électrique"> Électrique</label>
              </div>
            </div>
            <div class="field-item" id="budgetMensuelField">
              <label><span class="step-icon" aria-hidden="true">💶</span>Budget mensuel souhaité</label>
              <div class="choice-grid">
                <label class="radio-option"><input type="radio" name="budget" value="Moins de 300 €/mois"> Moins de 300 €/mois</label>
                <label class="radio-option"><input type="radio" name="budget" value="300 à 500 €/mois"> 300 à 500 €/mois</label>
                <label class="radio-option"><input type="radio" name="budget" value="500 à 700 €/mois"> 500 à 700 €/mois</label>
                <label class="radio-option"><input type="radio" name="budget" value="700 à 1 000 €/mois"> 700 à 1 000 €/mois</label>
                <label class="radio-option"><input type="radio" name="budget" value="Plus de 1 000 €/mois"> Plus de 1 000 €/mois</label>
              </div>
            </div>
            <div class="field-item" id="budgetAchatField" style="display:none;">
              <label><span class="step-icon" aria-hidden="true">💰</span>Budget d'achat souhaité</label>
              <div class="choice-grid">
                <label class="radio-option"><input type="radio" name="budgetAchat" value="Moins de 10 000€"> Moins de 10 000€</label>
                <label class="radio-option"><input type="radio" name="budgetAchat" value="10 000€ – 20 000€"> 10 000€ – 20 000€</label>
                <label class="radio-option"><input type="radio" name="budgetAchat" value="20 000€ – 35 000€"> 20 000€ – 35 000€</label>
                <label class="radio-option"><input type="radio" name="budgetAchat" value="Plus de 35 000€"> Plus de 35 000€</label>
              </div>
            </div>
          </div>
        </div>

        <div class="form-step" data-step="5">
          <label><span class="step-icon" aria-hidden="true">🆕</span>Le véhicule recherché est-il :</label>
          <div class="choice-grid">
            <label class="radio-option"><input type="radio" name="neufOccasion" value="Neuf"> Neuf</label>
            <label class="radio-option"><input type="radio" name="neufOccasion" value="Occasion"> Occasion</label>
            <label class="radio-option"><input type="radio" name="neufOccasion" value="Peu importe"> Peu importe</label>
          </div>
        </div>

        <div class="form-step" data-step="6" data-hide-if-achat="true">
          <label><span class="step-icon" aria-hidden="true">🛣️</span>Quel kilométrage annuel prévoyez-vous ?</label>
          <div class="choice-grid">
            <label class="radio-option"><input type="radio" name="kilometrage" value="Moins de 10 000 km"> Moins de 10 000 km</label>
            <label class="radio-option"><input type="radio" name="kilometrage" value="10 000 à 20 000 km"> 10 000 à 20 000 km</label>
            <label class="radio-option"><input type="radio" name="kilometrage" value="20 000 à 30 000 km"> 20 000 à 30 000 km</label>
            <label class="radio-option"><input type="radio" name="kilometrage" value="Plus de 30 000 km"> Plus de 30 000 km</label>
          </div>
        </div>

        <div class="form-step" data-step="7" data-hide-if-achat="true">
          <label><span class="step-icon" aria-hidden="true">📆</span>Quelle durée de contrat souhaitez-vous ?</label>
          <div class="choice-grid">
            <label class="radio-option"><input type="radio" name="dureeContrat" value="36 mois"> 36 mois</label>
            <label class="radio-option"><input type="radio" name="dureeContrat" value="48 mois"> 48 mois</label>
            <label class="radio-option"><input type="radio" name="dureeContrat" value="60 mois"> 60 mois</label>
            <label class="radio-option"><input type="radio" name="dureeContrat" value="Je ne sais pas encore"> Je ne sais pas encore</label>
          </div>
        </div>

        <div class="form-step" data-step="8">
          <label><span class="step-icon" aria-hidden="true">💰</span>Disposez-vous d'un apport ?</label>
          <div class="choice-grid">
            <label class="radio-option"><input type="radio" name="apport" value="0 €"> 0 €</label>
            <label class="radio-option"><input type="radio" name="apport" value="Moins de 2 000 €"> Moins de 2 000 €</label>
            <label class="radio-option"><input type="radio" name="apport" value="2 000 à 5 000 €"> 2 000 à 5 000 €</label>
            <label class="radio-option"><input type="radio" name="apport" value="Plus de 5 000 €"> Plus de 5 000 €</label>
          </div>
        </div>

        <div class="form-step" data-step="9">
          <label><span class="step-icon" aria-hidden="true">🚚</span>Quand souhaitez-vous recevoir votre véhicule ?</label>
          <div class="choice-grid">
            <label class="radio-option"><input type="radio" name="dateLivraison" value="Dès que possible"> Dès que possible</label>
            <label class="radio-option"><input type="radio" name="dateLivraison" value="Dans 1 mois"> Dans 1 mois</label>
            <label class="radio-option"><input type="radio" name="dateLivraison" value="Dans 3 mois"> Dans 3 mois</label>
            <label class="radio-option"><input type="radio" name="dateLivraison" value="Plus tard"> Plus tard</label>
          </div>
        </div>

        <div class="form-step" data-step="10">
          <label><span class="step-icon" aria-hidden="true">🔄</span>Avez-vous un véhicule à faire reprendre ?</label>
          <div class="field-stack">
            <div class="field-item">
              <div class="radio-group">
                <label class="radio-option"><input type="radio" name="vehiculeReprise" value="Oui"> Oui</label>
                <label class="radio-option"><input type="radio" name="vehiculeReprise" value="Non" checked> Non</label>
              </div>
            </div>
            <div class="field-item" id="vehiculeRepriseField" style="display:none;">
              <label for="fVehiculeRepriseDetails">Véhicule concerné</label>
              <input type="text" id="fVehiculeRepriseDetails" name="vehiculeRepriseDetails" placeholder="Ex : Peugeot 208, 2019, 45 000 km">
            </div>
          </div>
        </div>

        <div class="form-step" data-step="11" data-eligibility-only="true">
          <label><span class="step-icon" aria-hidden="true">💼</span>Quel est votre statut professionnel ?</label>
          <div class="choice-grid">
            <label class="radio-option"><input type="radio" name="statutPro" value="CDI"> CDI</label>
            <label class="radio-option"><input type="radio" name="statutPro" value="CDD"> CDD</label>
            <label class="radio-option"><input type="radio" name="statutPro" value="Indépendant"> Indépendant / Freelance</label>
            <label class="radio-option"><input type="radio" name="statutPro" value="Retraité"> Retraité</label>
            <label class="radio-option"><input type="radio" name="statutPro" value="Étudiant"> Étudiant</label>
            <label class="radio-option"><input type="radio" name="statutPro" value="Sans emploi"> Sans emploi</label>
          </div>
        </div>

        <div class="form-step" data-step="12" data-eligibility-only="true">
          <label for="fRevenus"><span class="step-icon" aria-hidden="true">💵</span>Quels sont vos revenus mensuels nets ?</label>
          <input type="number" id="fRevenus" name="revenus" min="0" step="50" placeholder="Ex : 1800">
          <div class="field-hint">En euros, avant impôt sur le revenu.</div>
        </div>

        <div class="form-step" data-step="13" data-eligibility-only="true">
          <label for="fCharges"><span class="step-icon" aria-hidden="true">🧾</span>Quel est le montant de vos charges mensuelles ?</label>
          <input type="number" id="fCharges" name="charges" min="0" step="10" placeholder="Ex : 400">
          <div class="field-hint">Loyer, crédits en cours, pension alimentaire versée...</div>
        </div>

        <div class="form-step" data-step="14" data-eligibility-only="true">
          <label><span class="step-icon" aria-hidden="true">⏳</span>Depuis combien de temps êtes-vous dans votre emploi / activité actuelle ?</label>
          <div class="choice-grid">
            <label class="radio-option"><input type="radio" name="anciennete" value="Moins de 6 mois"> Moins de 6 mois</label>
            <label class="radio-option"><input type="radio" name="anciennete" value="6 mois à 2 ans"> 6 mois à 2 ans</label>
            <label class="radio-option"><input type="radio" name="anciennete" value="Plus de 2 ans"> Plus de 2 ans</label>
          </div>
        </div>

        <div class="form-step" data-step="15" data-eligibility-only="true">
          <label><span class="step-icon" aria-hidden="true">🏦</span>Avez-vous vérifié si vous êtes fiché à la Banque de France (FICP) ?</label>
          <div class="choice-grid">
            <label class="radio-option"><input type="radio" name="ficp" value="Non, pas fiché" checked> Non, je ne suis pas fiché</label>
            <label class="radio-option"><input type="radio" name="ficp" value="Oui, fiché"> Oui, je suis fiché</label>
            <label class="radio-option"><input type="radio" name="ficp" value="Je n'ai pas vérifié"> Je n'ai pas vérifié</label>
          </div>
        </div>

        <div class="form-step" data-step="16">
          <label><span class="step-icon" aria-hidden="true">📇</span>Vos coordonnées</label>
          <div class="field-grid">
            <div class="field-item">
              <label for="fPrenom">Prénom</label>
              <input type="text" id="fPrenom" name="prenom" autocomplete="given-name">
            </div>
            <div class="field-item">
              <label for="fNom">Nom</label>
              <input type="text" id="fNom" name="nom" autocomplete="family-name">
            </div>
            <div class="field-item">
              <label for="fAge">Âge</label>
              <input type="number" id="fAge" name="age" min="1" max="120" placeholder="Ex : 32">
            </div>
            <div class="field-item">
              <label for="fTelephone">Téléphone</label>
              <input type="tel" id="fTelephone" name="telephone" autocomplete="tel">
            </div>
            <div class="field-item full">
              <label for="fEmail">Email</label>
              <input type="email" id="fEmail" name="email" autocomplete="email">
            </div>
            <div class="field-item full" id="entrepriseField" style="display:none;">
              <label for="fEntreprise">Nom de l'entreprise</label>
              <input type="text" id="fEntreprise" name="entreprise" autocomplete="organization">
            </div>
          </div>
        </div>

        <div class="form-step" data-step="17">
          <label for="fMessage"><span class="step-icon" aria-hidden="true">💬</span>Un message à ajouter ?</label>
          <textarea id="fMessage" name="message" rows="3" placeholder="Précisez votre besoin, budget, délai... (optionnel)"></textarea>
        </div>

        <p class="step-error" id="stepError"></p>

        <div class="stepper-nav" id="stepperNav">
          <button type="button" class="step-back" id="stepBack">← Précédent</button>
          <button type="button" class="step-skip" id="stepSkip" style="display:none;">Passer cette question</button>
          <button type="button" class="btn-primary" id="stepNext">Suivant</button>
        </div>

        <div class="form-status" id="formStatus">
          <p id="formStatusText"></p>
        </div>

        <div class="success-screen" id="successScreen">
          <div class="success-icon">🎉</div>
          <h2>Votre demande a bien été envoyée !</h2>
          <p>Votre dossier vient d'être transmis à notre réseau de partenaires.</p>
          <div class="success-steps">
            <div class="s-label">Les prochaines étapes</div>
            <div class="s-item">✓ Analyse de votre dossier</div>
            <div class="s-item">✓ Recherche de la meilleure offre</div>
            <div class="s-item">✓ Appel d'un conseiller sous 24h</div>
          </div>
          <div class="success-contact">
            <p>📞 Besoin d'aller plus vite ?</p>
            <div class="success-actions">
              <a class="whatsapp-btn" href="https://taap.it/elevenleasewhatsapp" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 6.32A8.86 8.86 0 0012.05 4c-4.9 0-8.9 4-8.9 8.9 0 1.57.42 3.1 1.2 4.44L3 22l4.8-1.26a8.9 8.9 0 004.25 1.08h0c4.9 0 8.9-4 8.9-8.9 0-2.38-.93-4.62-2.35-6.6zm-5.55 13.7h0a7.4 7.4 0 01-3.77-1.03l-.27-.16-2.8.74.75-2.73-.18-.28a7.38 7.38 0 01-1.13-3.94c0-4.08 3.32-7.4 7.4-7.4 1.98 0 3.84.77 5.24 2.17a7.35 7.35 0 012.16 5.23c0 4.08-3.32 7.4-7.4 7.4zm4.06-5.54c-.22-.11-1.31-.65-1.52-.72-.2-.08-.35-.11-.5.11-.15.22-.57.72-.7.87-.13.15-.26.16-.48.05-.22-.11-.94-.35-1.79-1.1-.66-.6-1.1-1.33-1.24-1.55-.13-.22-.01-.34.1-.45.1-.1.22-.26.33-.39.11-.13.15-.22.22-.37.07-.15.04-.28-.02-.39-.06-.11-.5-1.21-.69-1.66-.18-.43-.36-.38-.5-.38h-.43c-.15 0-.39.05-.59.28-.2.22-.78.76-.78 1.86s.8 2.16.91 2.31c.11.15 1.57 2.4 3.81 3.36.53.23.95.37 1.27.47.53.17 1.02.15 1.4.09.43-.06 1.31-.53 1.49-1.05.18-.51.18-.95.13-1.05-.05-.1-.2-.16-.42-.27z"/></svg>
                Discuter sur WhatsApp
              </a>
              <a class="btn-outline" href="/">← Retour à l'accueil</a>
            </div>
          </div>
          <button type="button" class="restart-link" id="restartWizardSuccess">← Faire une nouvelle simulation</button>
        </div>

        <p class="form-note" id="formNote">En envoyant ce formulaire, vous acceptez d'être recontacté par notre réseau de partenaires.</p>
      </form>
    </div>
  </div>
</section>

<footer>
  <div class="wrap footer-bottom">
    © 2026 Eleven Lease. Les véhicules et loyers affichés sont donnés à titre indicatif et soumis à acceptation du dossier par nos partenaires financiers.
  </div>
</footer>

