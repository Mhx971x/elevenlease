---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('articles');
  return entries.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const canonicalPath = `/articles/${entry.id}.html`;
const canonicalUrl = `https://elevenlease.fr${canonicalPath}`;
const isoDate = entry.data.publishDate.toISOString();

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: isoDate,
  dateModified: isoDate,
  url: canonicalUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
  author: { '@type': 'Organization', name: 'Eleven Lease', url: 'https://elevenlease.fr/' },
  publisher: {
    '@type': 'Organization',
    name: 'Eleven Lease',
    logo: { '@type': 'ImageObject', url: 'https://elevenlease.fr/eleven-lease-logo.png' },
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://elevenlease.fr/' },
    { '@type': 'ListItem', position: 2, name: 'Articles', item: 'https://elevenlease.fr/articles.html' },
    { '@type': 'ListItem', position: 3, name: entry.data.title, item: canonicalUrl },
  ],
};

const dateLabel = entry.data.publishDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---
<BaseLayout
  title={`${entry.data.title} | Eleven Lease`}
  description={entry.data.description}
  path={canonicalPath}
  ogType="article"
  active="articles"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <section class="article-hero">
    <div class="wrap">
      <a href="/articles.html" class="back-link">← Tous les articles</a>
      <div class="article-cat">{entry.data.category}</div>
      <h1>{entry.data.title}</h1>
      <div class="article-meta-row">
        <span>{dateLabel}</span>
        <span class="dot-sep">·</span>
        <span>{entry.data.readTime} de lecture</span>
      </div>
    </div>
  </section>

  <section class="article-body">
    <div class="wrap">
      <div class="prose">
        <Content />
      </div>
    </div>
  </section>

  <section class="article-cta">
    <div class="wrap">
      <h2>Un projet de leasing en tête ?</h2>
      <p>Décrivez-le en quelques minutes, notre réseau de partenaires financiers s'occupe du reste.</p>
      <a href="/simulation.html" class="btn-primary">Simuler mon leasing</a>
    </div>
  </section>
</BaseLayout>

<style>
  .article-hero{padding:150px 0 40px;border-bottom:1px solid var(--border);}
  .back-link{display:inline-block;font-size:14px;color:var(--text-dim);margin-bottom:24px;transition:color .2s ease;}
  .back-link:hover{color:var(--accent-1);}
  .article-cat{font-size:12.5px;color:var(--accent-1);text-transform:uppercase;letter-spacing:0.06em;font-weight:600;margin-bottom:14px;}
  .article-hero h1{font-size:clamp(28px,4.4vw,44px);max-width:780px;}
  .article-meta-row{display:flex;align-items:center;gap:10px;color:var(--text-faint);font-size:13.5px;margin-top:18px;}
  .dot-sep{opacity:0.6;}

  .article-body{padding:56px 0 80px;}
  .prose{max-width:700px;color:var(--text-dim);font-size:16px;line-height:1.8;}
  .prose :global(h2){color:var(--text);font-family:'Space Grotesk',sans-serif;font-weight:700;font-size:clamp(20px,2.8vw,26px);letter-spacing:-0.01em;margin:44px 0 18px;}
  .prose :global(h2:first-child){margin-top:0;}
  .prose :global(h3){color:var(--text);font-family:'Space Grotesk',sans-serif;font-weight:600;font-size:18px;margin:32px 0 14px;}
  .prose :global(p){margin-bottom:20px;}
  .prose :global(ul){margin:0 0 20px;padding-left:22px;display:flex;flex-direction:column;gap:10px;}
  .prose :global(li){padding-left:4px;}
  .prose :global(li::marker){color:var(--accent-1);}
  .prose :global(strong){color:var(--text);font-weight:600;}
  .prose :global(a){color:var(--text);text-decoration:underline;text-underline-offset:3px;text-decoration-color:var(--accent-1);transition:color .2s ease;}
  .prose :global(a:hover){color:var(--accent-1);}
  .prose :global(hr){border:none;border-top:1px solid var(--border);margin:40px 0;}

  .article-cta{padding:80px 0 96px;text-align:center;border-top:1px solid var(--border);}
  .article-cta h2{font-size:clamp(24px,3.4vw,32px);}
  .article-cta p{color:var(--text-dim);font-size:15px;max-width:460px;margin:14px auto 28px;}
  .btn-primary{
    background:var(--accent);color:#fff;padding:16px 28px;border-radius:100px;font-weight:600;font-size:15px;
    transition:transform .2s ease, filter .2s ease, box-shadow .3s ease;display:inline-block;
  }
  .btn-primary:hover{filter:brightness(1.12);transform:translateY(-2px);box-shadow:0 8px 24px rgba(255,0,127,0.25);}
  .btn-primary:active{transform:scale(.96);}
</style>
