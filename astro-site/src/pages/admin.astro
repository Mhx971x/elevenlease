  // côté fonction edge un rebuild Vercel : le site public se republie
  // automatiquement avec le catalogue à jour, sans intervention manuelle.
  // ============================================================
  const VEHICLE_FIELD_KEYS = [
    'brand', 'name', 'type', 'condition', 'price', 'km', 'duration', 'fuel',
    'transmission', 'places', 'finition', 'description',
    'options_confort', 'options_exterieur', 'options_interieur', 'options_technologie',
    'annee', 'puissance', 'moteur', 'autonomie_elec', 'autonomie_cumulee',
