  function renderVehicles(){
    const query = vehiclesSearchInput.value.trim().toLowerCase();
    const statusVal = vehiclesStatusFilter.value;
    const sortVal = vehiclesSortSelect.value;

    updateVehiclesStats();

    let filtered = allVehicles.filter(v => {
      const isActive = v.active !== false;
      if(statusVal === 'active' && !isActive) return false;
      if(statusVal === 'inactive' && isActive) return false;
      if(!query) return true;
      const haystack = [v.brand, v.name, v.finition].filter(Boolean).join(' ').toLowerCase();
      return haystack.includes(query);
    });

    filtered = filtered.slice().sort((a, b) => {
      if(sortVal === 'name') return ((a.brand||'')+(a.name||'')).localeCompare((b.brand||'')+(b.name||''), 'fr');
      if(sortVal === 'price-asc') return (a.price || 0) - (b.price || 0);
      if(sortVal === 'price-desc') return (b.price || 0) - (a.price || 0);
      const da = new Date(a.created_at || 0), db = new Date(b.created_at || 0);
      return sortVal === 'old' ? da.getTime() - db.getTime() : db.getTime() - da.getTime();
    });

    if(filtered.length === 0){
      vehicleList.style.display = 'none';
      vehiclesEmptyState.style.display = 'block';
      return;
    }
    vehiclesEmptyState.style.display = 'none';
    vehicleList.style.display = 'flex';

    vehicleList.innerHTML = filtered.map((v, i) => buildVehicleCard(v, i)).join('');
    attachVehicleCardListeners(vehicleList);
