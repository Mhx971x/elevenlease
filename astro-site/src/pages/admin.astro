  function refreshCard(lead: Lead){
    const card = leadList.querySelector('.lead-card[data-id="' + CSS.escape(String(lead.id)) + '"]');
    if(!card) return;
    const index = Array.from(leadList.children).indexOf(card);
    const wrapper = document.createElement('div');
    wrapper.innerHTML = buildCard(lead, index);
    const newCard = wrapper.firstElementChild as HTMLElement;
    if(card.classList.contains('open')){
      newCard.classList.add('open');
      const detail = newCard.querySelector('.lead-detail') as HTMLElement;
      detail.style.height = 'auto';
      detail.style.opacity = '1';
