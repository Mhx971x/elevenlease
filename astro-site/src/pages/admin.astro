  function renderPhotoPreviews(){
    photoPreviewGrid.innerHTML = photoPreviews.map(p =>
      '<div class="photo-preview-item' + (p.uploading ? ' uploading' : '') + '" data-id="' + p.id + '">' +
        '<img src="' + p.url + '" alt="">' +
        (p.uploading ? '' : '<button type="button" class="photo-preview-remove" data-id="' + p.id + '">×</button>') +
      '</div>'
    ).join('');
    photoPreviewGrid.querySelectorAll<HTMLButtonElement>('.photo-preview-remove').forEach(btn => {
      btn.addEventListener('click', () => {
        photoPreviews = photoPreviews.filter(p => p.id !== btn.dataset.id);
        renderPhotoPreviews();
      });
    });
  }

  async function uploadPhoto(file: File){
    if(!currentUploadFolder) currentUploadFolder = crypto.randomUUID();
    const id = 'up-' + Math.random().toString(36).slice(2);
    photoPreviews.push({ id, url: URL.createObjectURL(file), uploading: true });
    renderPhotoPreviews();
    activeUploads++;
    saveVehicleBtn.disabled = true;
    try{
      const res = await callAdminVehiclesFunction({
        password: sessionStorage.getItem('adminPassword'),
        action: 'create-upload-url',
        folder: currentUploadFolder,
        filename: file.name,
      });
      const { error } = await supabaseClient.storage.from('vehicle-photos').uploadToSignedUrl(res.path, res.token, file);
      if(error) throw error;
      const preview = photoPreviews.find(p => p.id === id);
      if(preview){ preview.url = res.publicUrl; preview.uploading = false; }
      renderPhotoPreviews();
    }catch(err: any){
      console.error(err);
      photoPreviews = photoPreviews.filter(p => p.id !== id);
      renderPhotoPreviews();
      alert("Échec de l'upload d'une photo : " + err.message);
    }finally{
      activeUploads--;
      if(activeUploads === 0) saveVehicleBtn.disabled = false;
    }
  }

  function handleFiles(files: FileList | null){
    if(!files) return;
    Array.from(files).forEach(file => uploadPhoto(file));
  }

  photoDropzone.addEventListener('click', () => photoFileInput.click());
  photoFileInput.addEventListener('change', () => { handleFiles(photoFileInput.files); photoFileInput.value = ''; });
  photoDropzone.addEventListener('dragover', (e) => { e.preventDefault(); photoDropzone.classList.add('dragover'); });
  photoDropzone.addEventListener('dragleave', () => photoDropzone.classList.remove('dragover'));
  photoDropzone.addEventListener('drop', (e: DragEvent) => {
    e.preventDefault();
    photoDropzone.classList.remove('dragover');
    handleFiles(e.dataTransfer ? e.dataTransfer.files : null);
  });

  function openVehicleForm(vehicle?: VehicleAdmin){
    editingVehicleId = vehicle ? vehicle.id : null;
    currentUploadFolder = crypto.randomUUID();
    photoPreviews = (vehicle?.photos || []).map(url => ({ id: 'existing-' + url, url, uploading: false }));
    renderPhotoPreviews();

    vehicleForm.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('[data-field]').forEach(el => {
      const key = el.dataset.field!;
      let val: unknown = vehicle ? vehicle[key] : '';
      if(Array.isArray(val)) val = (val as string[]).join(', ');
      el.value = val != null ? String(val) : '';
    });

    vehicleFormTitle.textContent = vehicle ? 'Modifier le véhicule' : 'Ajouter un véhicule';
    saveVehicleBtn.textContent = vehicle ? 'Enregistrer les modifications' : 'Ajouter le véhicule';
    addVehiclePanel.classList.add('open');
    addVehiclePanel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function closeVehicleForm(){
    addVehiclePanel.classList.remove('open');
    vehicleForm.reset();
    photoPreviews = [];
    renderPhotoPreviews();
    editingVehicleId = null;
  }

  addVehicleBtn.addEventListener('click', () => openVehicleForm());
  cancelVehicleFormBtn.addEventListener('click', closeVehicleForm);

  vehicleForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    if(activeUploads > 0) return;

    const fields: Record<string, unknown> = {};
    vehicleForm.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('[data-field]').forEach(el => {
      const key = el.dataset.field!;
      if(VEHICLE_OPTIONS_KEYS.includes(key)){
        fields[key] = el.value.split(',').map(s => s.trim()).filter(Boolean);
      } else if(key === 'price'){
        fields[key] = el.value === '' ? null : Number(el.value);
      } else {
        fields[key] = el.value.trim();
      }
    });
    fields.photos = photoPreviews.filter(p => !p.uploading).map(p => p.url);

    saveVehicleBtn.disabled = true;
    const prevText = saveVehicleBtn.textContent;
    saveVehicleBtn.textContent = 'Enregistrement…';
    try{
      if(editingVehicleId){
        await callAdminVehiclesFunction({ password: sessionStorage.getItem('adminPassword'), action: 'update-details', id: editingVehicleId, fields });
      } else {
        await callAdminVehiclesFunction({ password: sessionStorage.getItem('adminPassword'), action: 'create', fields });
      }
      closeVehicleForm();
      await loadVehicles();
    }catch(err: any){
      console.error(err);
      alert("Impossible d'enregistrer le véhicule : " + err.message);
    }finally{
      saveVehicleBtn.disabled = false;
      saveVehicleBtn.textContent = prevText;
    }
  });

  vehiclesSearchInput.addEventListener('input', renderVehicles);
  vehiclesStatusFilter.addEventListener('change', renderVehicles);
  vehiclesSortSelect.addEventListener('change', renderVehicles);

  function showDashboard(){
    loginScreen.style.display = 'none';
    dashboard.style.display = 'block';
    logoutBtn.style.display = 'inline-block';
    loadLeads();
    loadMessages();
    loadVehicles();
  }

  loginForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    loginError.classList.remove('show');
    const password = passwordInput.value;
    if(!password) return;
    loginBtn.disabled = true;
    loginBtn.textContent = 'Vérification…';
    try{
      await callAdminFunction({ password });
      sessionStorage.setItem('adminPassword', password);
      showDashboard();
    }catch(err: any){
      showLoginError(err.message === 'Mot de passe incorrect' ? 'Mot de passe incorrect.' : err.message);
    }finally{
      loginBtn.disabled = false;
      loginBtn.textContent = 'Se connecter';
    }
  });

  logoutBtn.addEventListener('click', () => {
    sessionStorage.removeItem('adminPassword');
    location.reload();
  });

  refreshBtn.addEventListener('click', () => { loadLeads(); loadMessages(); loadVehicles(); });
  searchInput.addEventListener('input', renderLeads);
  statusFilter.addEventListener('change', renderLeads);
  sortSelect.addEventListener('change', renderLeads);
  messagesSearchInput.addEventListener('input', renderMessages);
  messagesStatusFilter.addEventListener('change', renderMessages);
  messagesSortSelect.addEventListener('change', renderMessages);

  // reprend la session si un mot de passe est déjà mémorisé (onglet en cours)
  if(sessionStorage.getItem('adminPassword')){
    showDashboard();
  }
</script>

</body>
</html>
