    const query = searchInput.value.trim().toLowerCase();
    const statusVal = statusFilter.value;
    const sortVal = sortSelect.value;

    updateStats();

    let filtered = allLeads.filter(lead => {
      if(statusVal && (lead.status || 'nouveau') !== statusVal) return false;
      if(!query) return true;
      const haystack = [lead.prenom, lead.nom, lead.email, lead.telephone, lead.vehicule, lead.entreprise, lead.type_vehicule_souhaite]
        .filter(Boolean).join(' ').toLowerCase();
      return haystack.includes(query);
    });

    filtered = filtered.slice().sort((a, b) => {
      if(sortVal === 'name') return ((a.nom||'')+(a.prenom||'')).localeCompare((b.nom||'')+(b.prenom||''), 'fr');
      const da = new Date(a.created_at || 0), db = new Date(b.created_at || 0);
      return sortVal === 'old' ? da.getTime() - db.getTime() : db.getTime() - da.getTime();
    });

    if(filtered.length === 0){
      leadList.style.display = 'none';
      emptyState.style.display = 'block';
      return;
    }
    emptyState.style.display = 'none';
    leadList.style.display = 'flex';

