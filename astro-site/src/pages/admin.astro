---
// Espace admin interne — pas de layout partagé (pas de nav publique,
// pas d'indexation) : head minimal construit directement ici.
---
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<title>Espace admin | Eleven Lease</title>
<link rel="icon" type="image/png" href="/favicon.png">
<link rel="apple-touch-icon" href="/favicon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style is:global>
  :root{
    --bg:#0a0a0a;
    --surface:#141414;
    --surface-2:#1c1c1c;
    --border:#2a2a2a;
    --text:#ffffff;
    --text-dim:#9a9a9a;
    --text-faint:#5c5c5c;
    --accent-1:#ff007f;
    --accent-2:#8d0a32;
    --accent:linear-gradient(135deg,var(--accent-1),var(--accent-2));
  }
  *{margin:0;padding:0;box-sizing:border-box;}
  body{
    background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;
    line-height:1.5;min-height:100vh;
  }
  h1,h2,.display{font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.02em;}
  a{color:inherit;text-decoration:none;}
  .wrap{max-width:1080px;margin:0 auto;padding:0 32px;}
  @media(max-width:768px){ .wrap{padding:0 20px;} }

  header{border-bottom:1px solid var(--border);padding:18px 0;}
  .header-row{display:flex;align-items:center;justify-content:space-between;}
  .logo{display:flex;align-items:center;gap:10px;}
  .logo-icon{width:106px;height:46px;background-image:url('/eleven-lease-logo.png');background-repeat:no-repeat;background-size:contain;background-position:center;flex:none;}
  .logo-tag{font-size:12px;color:var(--text-faint);border-left:1px solid var(--border);padding-left:14px;margin-left:4px;}
  .btn-ghost{
    border:1px solid var(--border);padding:9px 18px;border-radius:100px;
    font-weight:600;font-size:13.5px;color:var(--text);background:none;cursor:pointer;
    transition:border-color .2s ease, transform .2s ease;
  }
  .btn-ghost:hover{border-color:#555;transform:translateY(-1px);}
  .btn-primary{
    background:var(--accent);color:#fff;padding:10px 22px;border-radius:100px;border:none;
    font-weight:600;font-size:13.5px;cursor:pointer;display:inline-block;font-family:inherit;
    transition:transform .2s ease, filter .2s ease;
  }
  .btn-primary:hover{filter:brightness(1.12);transform:translateY(-1px);}
  .btn-primary:active{transform:scale(.97);}
  .btn-primary:disabled{opacity:.5;cursor:default;transform:none;}

  /* login screen */
  #loginScreen{min-height:calc(100vh - 66px);display:flex;align-items:center;justify-content:center;padding:32px;}
  .login-card{
    width:100%;max-width:380px;border:1px solid var(--border);border-radius:20px;
    padding:40px 34px;background:var(--surface);
    animation:fadeUp .6s cubic-bezier(.16,1,.3,1) both;
  }
  @keyframes fadeUp{ from{opacity:0;transform:translateY(16px);} to{opacity:1;transform:translateY(0);} }
  .login-card h1{font-size:22px;margin-bottom:8px;}
  .login-card p{color:var(--text-dim);font-size:14px;margin-bottom:26px;}
  .login-card input{
    width:100%;background:var(--bg);border:1px solid var(--border);border-radius:10px;
    padding:13px 16px;color:var(--text);font-size:15px;font-family:inherit;
    transition:border-color .2s ease, box-shadow .2s ease;
  }
  .login-card input:focus{outline:none;border-color:var(--accent-1);box-shadow:0 0 0 3px rgba(255,0,127,0.15);}
  .login-card .btn-primary{width:100%;margin-top:16px;padding:13px 22px;}
  .login-error{color:#ff6b6b;font-size:13px;margin-top:14px;display:none;}
  .login-error.show{display:block;}

  /* dashboard */
  #dashboard{display:none;padding:40px 0 80px;}
  .dash-head{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;margin-bottom:28px;}
  .dash-head h1{font-size:clamp(24px,3vw,32px);}
  .dash-head p{color:var(--text-dim);font-size:14px;margin-top:6px;}
  .dash-actions{display:flex;gap:10px;align-items:center;flex-wrap:wrap;}

  /* tabs */
  .tab-bar{display:flex;gap:10px;margin-bottom:24px;flex-wrap:wrap;}
  .tab-btn{
    display:inline-flex;align-items:center;gap:8px;font-size:14px;font-weight:600;color:var(--text-dim);
    background:var(--surface);border:1px solid var(--border);border-radius:100px;padding:10px 18px;
    cursor:pointer;font-family:inherit;transition:border-color .2s ease, color .2s ease, background .2s ease, transform .2s ease;
  }
  .tab-btn:hover{border-color:#555;transform:translateY(-1px);}
  .tab-btn.active{background:var(--accent);color:#fff;border-color:transparent;}
  .tab-count{
    display:none;align-items:center;justify-content:center;min-width:19px;height:19px;padding:0 5px;
    border-radius:100px;background:var(--accent-1);color:#fff;font-size:11px;font-weight:700;line-height:1;
  }
  .tab-btn.active .tab-count{background:rgba(255,255,255,0.28);}
  .tab-panel{display:none;}
  .tab-panel.active{display:block;}

  /* stats */
  .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:26px;}
  @media(max-width:640px){ .stats-row{grid-template-columns:1fr 1fr;} }
  .stats-row-3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:26px;}
  @media(max-width:640px){ .stats-row-3{grid-template-columns:1fr;} }
  .stat-card{
    border:1px solid var(--border);border-radius:14px;padding:18px 20px;background:var(--surface);
    opacity:0;transform:translateY(10px);transition:opacity .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1), border-color .25s ease;
  }
  .stat-card.in{opacity:1;transform:translateY(0);}
  .stat-card.in:hover{border-color:#444;transform:translateY(-3px);}
  .stat-card .num{font-family:'Space Grotesk',sans-serif;font-size:26px;font-weight:700;}
  .stat-card .label{font-size:12.5px;color:var(--text-dim);margin-top:4px;}
  .stat-card.accent .num{color:var(--accent-1);}

  /* toolbar */
  .toolbar{display:flex;gap:10px;margin-bottom:22px;flex-wrap:wrap;}
  .toolbar input, .toolbar select{
    background:var(--surface);border:1px solid var(--border);border-radius:10px;
    padding:10px 14px;color:var(--text);font-size:14px;font-family:inherit;
    transition:border-color .2s ease, box-shadow .2s ease;
  }
  .toolbar input{flex:1;min-width:200px;}
  .toolbar input:focus, .toolbar select:focus{outline:none;border-color:var(--accent-1);box-shadow:0 0 0 3px rgba(255,0,127,0.15);}

  /* lead cards */
  .lead-list{display:flex;flex-direction:column;gap:10px;}
  .lead-card{
    border:1px solid var(--border);border-radius:16px;background:var(--surface);overflow:hidden;
    opacity:0;animation:cardIn .45s cubic-bezier(.16,1,.3,1) forwards;
    transition:border-color .25s ease, box-shadow .25s ease;
  }
  .lead-card:hover{border-color:#3a3a3a;box-shadow:0 8px 24px rgba(0,0,0,0.3);}
  @keyframes cardIn{ from{opacity:0;transform:translateY(8px);} to{opacity:1;transform:translateY(0);} }

  .lead-card-header{display:flex;align-items:center;gap:16px;padding:16px 20px;cursor:pointer;user-select:none;}
  .lead-avatar{
    width:38px;height:38px;border-radius:50%;background:var(--surface-2);border:1px solid var(--border);
    display:flex;align-items:center;justify-content:center;font-family:'Space Grotesk',sans-serif;
    font-weight:700;font-size:14px;flex:none;color:var(--text-dim);transition:background .25s ease, color .25s ease;
  }
  .lead-avatar.eligible{background:var(--accent);color:#fff;border-color:transparent;}
  .lead-main{flex:1;min-width:0;}
  .lead-name-row{display:flex;align-items:center;gap:9px;flex-wrap:wrap;}
  .lead-name{font-weight:600;font-size:15px;}
  .lead-sub{font-size:13px;color:var(--text-dim);margin-top:4px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
  .lead-meta{text-align:right;flex:none;display:flex;align-items:center;gap:14px;}
  .lead-date{font-size:12px;color:var(--text-faint);white-space:nowrap;}
  .lead-chevron{transition:transform .35s cubic-bezier(.16,1,.3,1);color:var(--text-faint);flex:none;}
  .lead-card.open .lead-chevron{transform:rotate(180deg);}
  .lead-card.open{border-color:#444;}

  .lead-detail{height:0;opacity:0;overflow:hidden;}
  .lead-card.open .lead-detail{height:auto;opacity:1;}
  .lead-detail-inner{padding:2px 20px 22px;border-top:1px solid var(--border);margin:0 0 0;padding-top:18px;}

  .detail-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:16px 20px;margin-bottom:18px;}
  .detail-item .d-label{font-size:10.5px;text-transform:uppercase;letter-spacing:.07em;color:var(--text-faint);margin-bottom:4px;}
  .detail-item .d-value{font-size:14px;color:var(--text);}

  .risk-note, .lead-message-box{
    background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:13px 15px;
    font-size:13.5px;color:var(--text-dim);line-height:1.6;margin-bottom:14px;
  }
  .risk-note{border-color:#3a2a2a;}
  .risk-note .d-label, .lead-message-box .d-label{
    font-size:10.5px;text-transform:uppercase;letter-spacing:.07em;color:var(--text-faint);margin-bottom:6px;display:block;
  }

  .lead-actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center;justify-content:space-between;margin-top:4px;}
  .quick-actions{display:flex;gap:8px;flex-wrap:wrap;}
  .quick-btn{
    display:inline-flex;align-items:center;gap:7px;font-size:12.5px;font-weight:600;
    padding:8px 14px;border-radius:100px;border:1px solid var(--border);color:var(--text);background:none;
    transition:border-color .2s ease, transform .2s ease;
  }
  .quick-btn:hover{border-color:#666;transform:translateY(-1px);}

  .badge{
    display:inline-flex;align-items:center;gap:6px;font-size:11.5px;padding:4px 11px;
    border-radius:100px;border:1px solid var(--border);white-space:nowrap;
  }
  .badge.eligible{background:var(--accent);color:#fff;border-color:transparent;}
  .badge.complex{color:var(--text-dim);}
  .badge.neutral{color:var(--text-faint);}
  .badge-dot{width:5px;height:5px;border-radius:50%;background:currentColor;flex:none;}

  .status-pill{
    font-size:11px;font-weight:600;padding:4px 10px;border-radius:100px;border:1px solid var(--border);
    color:var(--text-faint);white-space:nowrap;
  }
  .status-pill.traite{color:var(--text-dim);}
  .status-pill.nouveau{color:var(--accent-1);border-color:var(--accent-1);}

  .status-btn{
    display:inline-flex;align-items:center;gap:7px;font-size:12.5px;font-weight:600;
    padding:8px 15px;border-radius:100px;border:1px solid var(--border);background:none;color:var(--text-dim);
    cursor:pointer;font-family:inherit;transition:border-color .25s ease, color .25s ease, background .25s ease;
  }
  .status-btn .dot{width:7px;height:7px;border-radius:50%;background:var(--text-faint);transition:background .25s ease;flex:none;}
  .status-btn.nouveau{color:var(--accent-1);border-color:var(--accent-1);}
  .status-btn.nouveau .dot{background:var(--accent-1);}
  .status-btn:hover{border-color:#666;}
  .status-btn:disabled{opacity:.5;cursor:default;}

  .edit-btn, .delete-btn{
    display:inline-flex;align-items:center;gap:7px;font-size:12.5px;font-weight:600;
    padding:8px 15px;border-radius:100px;border:1px solid var(--border);background:none;color:var(--text-dim);
    cursor:pointer;font-family:inherit;transition:border-color .2s ease, color .2s ease, transform .2s ease;
  }
  .edit-btn:hover{border-color:#666;color:var(--text);transform:translateY(-1px);}
  .delete-btn:hover{border-color:#ff6b6b;color:#ff6b6b;transform:translateY(-1px);}
  .edit-btn:disabled, .delete-btn:disabled{opacity:.5;cursor:default;transform:none;}

  .lead-edit-form{display:none;}
  .lead-card.editing .lead-view{display:none;}
  .lead-card.editing .lead-edit-form{display:block;}
  .edit-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:14px 16px;margin-bottom:16px;}
  .edit-field{display:flex;flex-direction:column;gap:6px;font-size:12px;color:var(--text-dim);}
  .edit-field-full{margin-bottom:16px;}
  .edit-field input, .edit-field textarea{
    background:var(--bg);border:1px solid var(--border);border-radius:10px;
    padding:10px 12px;color:var(--text);font-size:13.5px;font-family:inherit;
    transition:border-color .2s ease, box-shadow .2s ease;
  }
  .edit-field textarea{resize:vertical;min-height:70px;}
  .edit-field input:focus, .edit-field textarea:focus{
    outline:none;border-color:var(--accent-1);box-shadow:0 0 0 3px rgba(255,0,127,0.15);
  }
  .edit-actions{display:flex;justify-content:flex-end;gap:10px;}
  .edit-actions .btn-ghost, .edit-actions .btn-primary{padding:9px 18px;font-size:13px;}

  /* onglet véhicules : miniatures, formulaire, glisser-déposer photos */
  .vehicle-thumb{width:48px;height:36px;border-radius:8px;object-fit:cover;background:var(--surface-2);border:1px solid var(--border);flex:none;}
  .vehicle-thumb-placeholder{
    width:48px;height:36px;border-radius:8px;background:var(--surface-2);border:1px solid var(--border);flex:none;
    display:flex;align-items:center;justify-content:center;font-size:16px;
  }
  .add-vehicle-panel{display:none;margin-bottom:22px;border:1px solid var(--border);border-radius:16px;background:var(--surface);padding:22px;}
  .add-vehicle-panel.open{display:block;}
  .add-vehicle-panel h2{font-size:17px;margin-bottom:18px;}
  .dropzone{
    border:2px dashed var(--border);border-radius:14px;padding:24px;text-align:center;
    color:var(--text-dim);font-size:13.5px;cursor:pointer;transition:border-color .2s ease, background .2s ease;
    margin-bottom:14px;
  }
  .dropzone:hover, .dropzone.dragover{border-color:var(--accent-1);background:rgba(255,0,127,0.05);}
  .photo-preview-grid{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:16px;}
  .photo-preview-item{position:relative;width:76px;height:56px;border-radius:8px;overflow:hidden;border:1px solid var(--border);background:var(--surface-2);}
  .photo-preview-item img{width:100%;height:100%;object-fit:cover;display:block;}
  .photo-preview-item.uploading{opacity:.5;}
  .photo-preview-remove{
    position:absolute;top:2px;right:2px;width:18px;height:18px;border-radius:50%;
    background:rgba(10,10,10,0.75);color:#fff;border:none;cursor:pointer;font-size:12px;line-height:1;
    display:flex;align-items:center;justify-content:center;
  }

  .empty-state, .loading-state, .error-state{
    text-align:center;padding:70px 20px;color:var(--text-dim);font-size:14.5px;
    border:1px solid var(--border);border-radius:16px;background:var(--surface);
  }
  .error-state{color:#ff8383;}
  .spinner{
    width:22px;height:22px;border-radius:50%;border:2px solid var(--border);border-top-color:var(--text);
    animation:spin .7s linear infinite;margin:0 auto 16px;
  }
  @keyframes spin{ to{transform:rotate(360deg);} }

  @media (prefers-reduced-motion: reduce){ *{animation:none !important;transition:none !important;} }
</style>
</head>
<body>

<header>
  <div class="wrap header-row">
    <div class="logo">
      <span class="logo-icon" role="img" aria-label="Eleven Lease"></span>      <span class="logo-tag">Espace admin</span>
    </div>
    <button class="btn-ghost" id="logoutBtn" style="display:none;">Se déconnecter</button>
  </div>
</header>

<div id="loginScreen">
  <div class="login-card">
    <h1>Accès réservé</h1>
    <p>Entrez le mot de passe admin pour consulter les demandes reçues.</p>
    <form id="loginForm">
      <input type="password" id="passwordInput" placeholder="Mot de passe" autocomplete="current-password" autofocus>
      <button type="submit" class="btn-primary" id="loginBtn">Se connecter</button>
      <div class="login-error" id="loginError"></div>
    </form>
  </div>
</div>

<div id="dashboard">
  <div class="wrap">
    <div class="dash-head">
      <div>
        <h1>Demandes reçues</h1>
        <p>Cliquez sur une demande pour voir tous les détails.</p>
      </div>
      <div class="dash-actions">
        <button class="btn-ghost" id="refreshBtn">Actualiser</button>
      </div>
    </div>

    <div class="tab-bar">
      <button type="button" class="tab-btn active" id="tabLeadsBtn">Demandes simulateur <span class="tab-count" id="leadsTabCount">0</span></button>
      <button type="button" class="tab-btn" id="tabMessagesBtn">Messages de contact <span class="tab-count" id="messagesTabCount">0</span></button>
      <button type="button" class="tab-btn" id="tabVehiclesBtn">Véhicules</button>
    </div>

    <div class="tab-panel active" id="leadsPanel">
      <div class="stats-row">
        <div class="stat-card accent" id="statTotalCard"><div class="num" id="statTotal">0</div><div class="label">Demandes au total</div></div>
        <div class="stat-card accent" id="statNouveauCard"><div class="num" id="statNouveau">0</div><div class="label">À traiter</div></div>
        <div class="stat-card" id="statTraiteCard"><div class="num" id="statTraite">0</div><div class="label">Traitées</div></div>
        <div class="stat-card" id="statEligibleCard"><div class="num" id="statEligible">0</div><div class="label">Profils éligibles</div></div>
      </div>

      <div class="toolbar">
        <input type="text" id="searchInput" placeholder="Rechercher un nom, un email, un véhicule…">
        <select id="statusFilter">
          <option value="">Tous les statuts</option>
          <option value="nouveau">À traiter</option>
          <option value="traite">Traité</option>
        </select>
        <select id="sortSelect">
          <option value="recent">Plus récent d'abord</option>
          <option value="old">Plus ancien d'abord</option>
          <option value="name">Par nom (A → Z)</option>
        </select>
      </div>

      <div id="loadingState" class="loading-state"><div class="spinner"></div>Chargement des demandes…</div>
      <div id="errorState" class="error-state" style="display:none;"></div>
      <div id="emptyState" class="empty-state" style="display:none;">Aucune demande ne correspond à votre recherche.</div>
      <div class="lead-list" id="leadList" style="display:none;"></div>
    </div>

    <div class="tab-panel" id="messagesPanel">
      <div class="stats-row-3">
        <div class="stat-card accent" id="msgStatTotalCard"><div class="num" id="msgStatTotal">0</div><div class="label">Messages au total</div></div>
        <div class="stat-card accent" id="msgStatNouveauCard"><div class="num" id="msgStatNouveau">0</div><div class="label">À traiter</div></div>
        <div class="stat-card" id="msgStatTraiteCard"><div class="num" id="msgStatTraite">0</div><div class="label">Traités</div></div>
      </div>

      <div class="toolbar">
        <input type="text" id="messagesSearchInput" placeholder="Rechercher un nom, un email…">
        <select id="messagesStatusFilter">
          <option value="">Tous les statuts</option>
          <option value="nouveau">À traiter</option>
          <option value="traite">Traité</option>
        </select>
        <select id="messagesSortSelect">
          <option value="recent">Plus récent d'abord</option>
          <option value="old">Plus ancien d'abord</option>
          <option value="name">Par nom (A → Z)</option>
        </select>
      </div>

      <div id="messagesLoadingState" class="loading-state"><div class="spinner"></div>Chargement des messages…</div>
      <div id="messagesErrorState" class="error-state" style="display:none;"></div>
      <div id="messagesEmptyState" class="empty-state" style="display:none;">Aucun message ne correspond à votre recherche.</div>
      <div class="lead-list" id="messageList" style="display:none;"></div>
    </div>

    <div class="tab-panel" id="vehiclesPanel">
      <div class="stats-row-3">
        <div class="stat-card accent" id="vehStatTotalCard"><div class="num" id="vehStatTotal">0</div><div class="label">Véhicules au total</div></div>
        <div class="stat-card accent" id="vehStatActiveCard"><div class="num" id="vehStatActive">0</div><div class="label">Actifs (visibles)</div></div>
        <div class="stat-card" id="vehStatInactiveCard"><div class="num" id="vehStatInactive">0</div><div class="label">Inactifs (masqués)</div></div>
      </div>

      <div class="toolbar">
        <input type="text" id="vehiclesSearchInput" placeholder="Rechercher une marque, un modèle…">
        <select id="vehiclesStatusFilter">
          <option value="">Tous les statuts</option>
          <option value="active">Actifs</option>
          <option value="inactive">Inactifs</option>
        </select>
        <select id="vehiclesSortSelect">
          <option value="recent">Plus récent d'abord</option>
          <option value="old">Plus ancien d'abord</option>
          <option value="name">Par nom (A → Z)</option>
          <option value="price-asc">Prix croissant</option>
          <option value="price-desc">Prix décroissant</option>
        </select>
        <button type="button" class="btn-primary" id="addVehicleBtn">+ Ajouter un véhicule</button>
      </div>

      <div class="add-vehicle-panel" id="addVehiclePanel">
        <h2 id="vehicleFormTitle">Ajouter un véhicule</h2>
        <form id="vehicleForm">
          <div class="edit-grid">
            <label class="edit-field"><span>Marque *</span><input type="text" data-field="brand" required></label>
            <label class="edit-field"><span>Modèle *</span><input type="text" data-field="name" required></label>
            <label class="edit-field"><span>Finition</span><input type="text" data-field="finition"></label>
            <label class="edit-field">
              <span>Type</span>
