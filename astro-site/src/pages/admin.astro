  function toggleCard(card: HTMLElement){
    if(card.dataset.animating === '1') return;
    const detail = card.querySelector('.lead-detail') as HTMLElement;
    card.classList.contains('open') ? closeCard(card, detail) : openCard(card, detail);
  }

  function openCard(card: HTMLElement, detail: HTMLElement){
    card.dataset.animating = '1';
    card.classList.add('open');
    const target = detail.scrollHeight;
    detail.style.overflow = 'hidden';
    const anim = detail.animate(
      [{ height: '0px', opacity: 0 }, { height: target + 'px', opacity: 1 }],
      { duration: 320, easing: cardEasing }
    );
    anim.onfinish = () => {
      detail.style.overflow = '';
      detail.style.height = '';
      card.dataset.animating = '';
    };
  }

  function closeCard(card: HTMLElement, detail: HTMLElement){
    card.dataset.animating = '1';
    const start = detail.scrollHeight;
    detail.style.overflow = 'hidden';
    const anim = detail.animate(
      [{ height: start + 'px', opacity: 1 }, { height: '0px', opacity: 0 }],
      { duration: 280, easing: cardEasing }
    );
    anim.onfinish = () => {
      card.classList.remove('open');
      detail.style.overflow = '';
      detail.style.height = '';
      card.dataset.animating = '';
    };
  }

