  async function onSaveEdit(e: Event){
    const btn = e.currentTarget as HTMLButtonElement;
    const id = btn.dataset.id!;
    const card = btn.closest('.lead-card') as HTMLElement;
    const fields: Record<string, string> = {};
    card.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('.lead-edit-form [data-field]').forEach(input => {
      fields[input.dataset.field!] = input.value.trim();
    });
    btn.disabled = true;
    const cancelBtn = card.querySelector('.cancel-edit-btn') as HTMLButtonElement | null;
    if(cancelBtn) cancelBtn.disabled = true;
    try{
      await callAdminFunction({ password: sessionStorage.getItem('adminPassword'), action: 'update-details', id, fields });
      const lead = allLeads.find(l => String(l.id) === String(id));
      if(lead) Object.assign(lead, fields);
      updateStats();
      if(lead) refreshCard(lead);
    }catch(err: any){
      console.error(err);
      btn.disabled = false;
      if(cancelBtn) cancelBtn.disabled = false;
      alert("Impossible d'enregistrer les modifications : " + err.message);
    }
