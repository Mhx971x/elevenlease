  ];
  const VEHICLE_OPTIONS_KEYS = ['options_confort', 'options_exterieur', 'options_interieur', 'options_technologie'];

  interface PhotoPreview { id: string; url: string; uploading: boolean; }
  let photoPreviews: PhotoPreview[] = [];
  let currentUploadFolder: string | null = null;
  let editingVehicleId: string | number | null = null;
  let activeUploads = 0;

  function updateVehiclesStats(){
    const total = allVehicles.length;
    const active = allVehicles.filter(v => v.active !== false).length;
    vehStatTotal.textContent = String(total);
    vehStatActive.textContent = String(active);
    vehStatInactive.textContent = String(total - active);
    document.querySelectorAll('#vehiclesPanel .stat-card').forEach((el, i) => setTimeout(() => el.classList.add('in'), i * 60));
  }

  function buildVehicleCard(v: VehicleAdmin, index: number){
    const isActive = v.active !== false;
    const statusCls = isActive ? 'nouveau' : 'traite';
    const thumb = v.photos && v.photos[0]
      ? '<img class="vehicle-thumb" src="' + escapeHtml(v.photos[0]) + '" alt="">'
      : '<div class="vehicle-thumb-placeholder">🚗</div>';
    const title = escapeHtml(v.brand + ' ' + v.name) + (v.finition ? ' ' + escapeHtml(v.finition) : '');
    const subLine = [v.price ? v.price + '€/mois' : '', v.condition, v.type].filter(Boolean).join(' · ') || 'Détails non renseignés';

    return (
      '<div class="lead-card" data-id="' + v.id + '" style="animation-delay:' + Math.min(index * 0.035, 0.3) + 's">' +
        '<div class="lead-card-header">' +
          thumb +
          '<div class="lead-main">' +
            '<div class="lead-name-row">' +
              '<span class="lead-name">' + title + '</span>' +
              '<span class="status-pill ' + statusCls + '">' + (isActive ? 'Actif' : 'Inactif') + '</span>' +
            '</div>' +
            '<div class="lead-sub">' + escapeHtml(subLine) + '</div>' +
          '</div>' +
          '<div class="lead-meta">' +
            '<span class="lead-date">' + relativeTime(v.created_at) + '</span>' +
            CHEVRON_SVG +
          '</div>' +
        '</div>' +
