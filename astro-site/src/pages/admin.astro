  function buildMessageCard(msg: ContactMessage, index: number){
    const status = msg.status || 'nouveau';
    const fullName = (msg.nom || '').trim() || 'Sans nom';
    const initial = (msg.nom || '?').trim().charAt(0).toUpperCase();
    const subLine = [msg.email, msg.telephone].filter(Boolean).join(' · ') || 'Aucun contact renseigné';
    const messageBox = msg.message
      ? '<div class="lead-message-box"><span class="d-label">Message</span>' + escapeHtml(msg.message) + '</div>'
      : '';
    const telHref = msg.telephone ? 'tel:' + msg.telephone.replace(/\s+/g, '') : '';
    const mailHref = msg.email ? 'mailto:' + msg.email : '';

    return (
      '<div class="lead-card" data-id="' + msg.id + '" style="animation-delay:' + Math.min(index * 0.035, 0.3) + 's">' +
        '<div class="lead-card-header">' +
          '<div class="lead-avatar">' + escapeHtml(initial) + '</div>' +
          '<div class="lead-main">' +
            '<div class="lead-name-row">' +
              '<span class="lead-name">' + escapeHtml(fullName) + '</span>' +
              '<span class="status-pill ' + status + '">' + (status === 'traite' ? 'Traité' : 'À traiter') + '</span>' +
            '</div>' +
            '<div class="lead-sub">' + escapeHtml(subLine) + '</div>' +
          '</div>' +
          '<div class="lead-meta">' +
            '<span class="lead-date">' + relativeTime(msg.created_at) + '</span>' +
            CHEVRON_SVG +
          '</div>' +
        '</div>' +
        '<div class="lead-detail">' +
          '<div class="lead-detail-inner">' +
            messageBox +
            '<div class="lead-actions">' +
              '<div class="quick-actions">' +
                (telHref ? '<a class="quick-btn" href="' + telHref + '">' + PHONE_SVG + 'Appeler</a>' : '') +
                (mailHref ? '<a class="quick-btn" href="' + mailHref + '">' + MAIL_SVG + 'Email</a>' : '') +
                '<button type="button" class="delete-btn" data-id="' + msg.id + '">Supprimer</button>' +
              '</div>' +
              '<button class="status-btn ' + status + '" data-id="' + msg.id + '" data-status="' + status + '"><span class="dot"></span>' + (status === 'traite' ? 'Marquer comme à traiter' : 'Marquer comme traité') + '</button>' +
            '</div>' +
          '</div>' +
        '</div>' +
      '</div>'
    );
  }

