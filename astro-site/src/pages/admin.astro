          '<div class="lead-detail-inner">' +
            '<div class="lead-actions">' +
              '<div class="quick-actions">' +
                '<a class="quick-btn" href="/vehicule/' + escapeHtml(v.slug) + '.html" target="_blank" rel="noopener">Voir la fiche</a>' +
                '<button type="button" class="edit-btn" data-id="' + v.id + '">Modifier</button>' +
                '<button type="button" class="delete-btn" data-id="' + v.id + '">Supprimer</button>' +
              '</div>' +
              '<button class="status-btn ' + statusCls + '" data-id="' + v.id + '" data-active="' + isActive + '"><span class="dot"></span>' + (isActive ? 'Désactiver (masquer)' : 'Activer (afficher)') + '</button>' +
            '</div>' +
          '</div>' +
        '</div>' +
      '</div>'
    );
