---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quelle est la différence entre LOA et LLD ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "En LOA, un prix de rachat est fixé dès la signature : vous savez depuis le début combien coûterait le véhicule si vous l'achetiez en fin de contrat. En LLD, aucune option d'achat n'est prévue à l'avance — la restitution est la finalité par défaut. C'est surtout ce niveau de flexibilité qui distingue les deux formules."
      }
    },
    {
      "@type": "Question",
      "name": "Faut-il obligatoirement un apport ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non. Un apport n'est pas obligatoire, mais il réduit mécaniquement votre loyer mensuel puisqu'il diminue le montant financé. Beaucoup de nos clients démarrent sans apport pour préserver leur trésorerie."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je faire une LOA si je suis fiché à la Banque de France ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "C'est un critère généralement bloquant chez la plupart des organismes de financement, mais chaque dossier reste étudié au cas par cas. Notre test d'éligibilité vous donne une première indication honnête, y compris dans cette situation."
      }
    },
    {
      "@type": "Question",
      "name": "Y a-t-il une limite de kilométrage avec Eleven Lease ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Non. Contrairement à une LOA classique où un forfait kilométrique est facturé en cas de dépassement, l'offre de leasing proposée par Eleven Lease est à kilométrage illimité, pour les particuliers comme pour les professionnels : aucun forfait à respecter, aucune régularisation à prévoir en fin de contrat."
      }
    },
    {
      "@type": "Question",
      "name": "Puis-je changer de véhicule avant la fin du contrat ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "C'est possible dans certains cas (rachat anticipé, transfert de contrat), mais les conditions varient selon l'organisme financier. Votre conseiller Eleven Lease étudie la meilleure option selon votre situation."
      }
    },
    {
      "@type": "Question",
      "name": "Quelle assurance est obligatoire en LOA ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Comme pour tout véhicule, l'assurance au tiers minimum est obligatoire. La plupart des organismes financiers exigent en plus une garantie tous risques pendant toute la durée du contrat, le véhicule ne vous appartenant pas encore."
      }
    },
    {
      "@type": "Question",
      "name": "La LOA est-elle adaptée aux véhicules électriques ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Oui, et c'est même une formule particulièrement adaptée : elle permet de profiter des dernières avancées technologiques (autonomie, recharge) sans supporter la décote liée à l'évolution rapide de cette motorisation."
      }
    },
    {
      "@type": "Question",
      "name": "Combien de temps pour obtenir une réponse ?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Comptez généralement 24 à 48h après réception d'un dossier complet. La simulation elle-même est instantanée et ne vous engage à rien."
      }
    }
  ]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Accueil", "item": "https://elevenlease.fr/" },
    { "@type": "ListItem", "position": 2, "name": "Guide LOA", "item": "https://elevenlease.fr/loa" }
  ]
};
---
<BaseLayout
  title="LOA voiture : fonctionnement et coût | Eleven Lease"
  description="Qu'est-ce que la LOA ? Fonctionnement, coût, éligibilité, fin de contrat : le guide complet de la location avec option d'achat par Eleven Lease."
  path="/loa"
  ogType="article"
  active="loa"
  showProgressBar
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <section class="page-hero">
    <div class="wrap">
      <div class="eyebrow"><span class="dot"></span> Guide leasing</div>
      <h1>La LOA, expliquée simplement.</h1>
      <p>La location avec option d'achat est devenue la manière la plus courante de rouler dans un véhicule neuf ou récent en France. Voici comment elle fonctionne, ce qu'elle coûte vraiment, et comment on vous aide à décrocher la bonne offre.</p>
      <div class="hero-actions">
        <a href="/simulation" class="btn-primary">Simuler mon leasing</a>
        <a href="/vehicules" class="btn-ghost">Découvrir les véhicules</a>
      </div>

      <div class="toc-card reveal">
        <div class="toc-title">Sommaire</div>
        <ul class="toc-list">
          <li><a href="#definition">Qu'est-ce que la LOA ?</a></li>
          <li><a href="#fonctionnement">Comment ça marche</a></li>
          <li><a href="#cout">Combien ça coûte</a></li>
          <li><a href="#avantages">Avantages et limites</a></li>
          <li><a href="#eligibilite">Suis-je éligible ?</a></li>
          <li><a href="#fin-de-contrat">Fin de contrat : vos options</a></li>
          <li><a href="#pourquoi-eleven-auto">Pourquoi passer par Eleven Lease</a></li>
          <li><a href="#faq">Questions fréquentes</a></li>
        </ul>
      </div>
    </div>
  </section>

  <section id="definition">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="section-eyebrow">01 — Les bases</div>
        <h2>Qu'est-ce que la LOA ?</h2>
      </div>
      <div class="body-text reveal">
        <p>La Location avec Option d'Achat vous permet de conduire un véhicule pendant une durée fixée à l'avance — généralement entre 24 et 60 mois — en échange d'un loyer mensuel. À la fin du contrat, trois choix s'offrent à vous : racheter le véhicule au prix convenu dès le départ, le restituer, ou repartir sur un nouveau modèle.</p>
        <p>C'est aujourd'hui le mode de financement automobile le plus choisi en France, loin devant le crédit classique — pour une raison simple : il combine mensualités maîtrisées et liberté de changer de véhicule régulièrement.</p>
        <p>La différence avec la LLD (location longue durée) ? En LOA, le prix de rachat final est fixé dès la signature du contrat. Vous savez, dès le premier jour, combien il vous en coûterait de devenir propriétaire si vous choisissiez cette option.</p>
      </div>
    </div>
  </section>

  <section id="fonctionnement" class="section-border">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="section-eyebrow">02 — Le parcours</div>
        <h2>Comment ça marche, en pratique.</h2>
      </div>
      <div class="steps stagger">
        <div class="step stagger-item">
          <div class="num">01</div>
          <h3>Vous choisissez</h3>
          <p>Véhicule neuf ou occasion, leasing en priorité. Parcourez notre catalogue ou décrivez ce que vous cherchez.</p>
        </div>
        <div class="step stagger-item">
          <div class="num">02</div>
          <h3>Vous réglez les paramètres</h3>
          <p>Durée du contrat, kilométrage annuel, apport éventuel : ces trois curseurs déterminent votre loyer.</p>
        </div>
        <div class="step stagger-item">
          <div class="num">03</div>
          <h3>Votre dossier est étudié</h3>
          <p>Revenus, charges, situation professionnelle : les critères habituels des organismes de financement.</p>
        </div>
        <div class="step stagger-item">
          <div class="num">04</div>
          <h3>Vous roulez</h3>
          <p>Contrat signé, véhicule livré. Vous payez un loyer fixe chaque mois, sans surprise.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="cout" class="section-border">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="section-eyebrow">03 — Le prix</div>
        <h2>Combien coûte une LOA ?</h2>
        <p>Votre loyer mensuel dépend de quatre leviers principaux.</p>
      </div>
      <div class="cost-levers stagger">
        <div class="cost-lever stagger-item"><strong>Le prix du véhicule</strong><span>Catalogue ou négocié — le point de départ du calcul.</span></div>
        <div class="cost-lever stagger-item"><strong>L'apport initial</strong><span>Facultatif. Plus il est élevé, plus le loyer mensuel baisse.</span></div>
        <div class="cost-lever stagger-item"><strong>La durée du contrat</strong><span>Plus elle est courte, plus la mensualité est élevée.</span></div>
        <div class="cost-lever stagger-item"><strong>La valeur de rachat finale</strong><span>Fixée à la signature, elle influence directement le loyer.</span></div>
      </div>
      <div class="example-box reveal">
        <p>Exemple concret, tiré de notre catalogue : une <strong>Peugeot 3008 neuve à partir de 359 €/mois</strong>, sur 37 mois, kilométrage illimité, sans apport. Le montant exact dépend toujours de votre profil et des conditions négociées par nos partenaires — <a href="/vehicules">voir le catalogue complet →</a></p>
      </div>
      <p class="indicative-note">Les loyers affichés sur Eleven Lease sont donnés à titre indicatif et confirmés après étude de votre dossier.</p>
    </div>
  </section>

  <section id="avantages" class="section-border">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="section-eyebrow">04 — À peser</div>
        <h2>Avantages et limites de la LOA.</h2>
      </div>
      <div class="pros-cons stagger">
        <div class="pc-card stagger-item">
          <h3>Ce qui joue en sa faveur</h3>
          <ul class="pc-list">
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--accent-1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Kilométrage illimité, aucun forfait à respecter</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--accent-1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Mensualités fixes, connues à l'avance</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--accent-1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Apport réduit, voire nul</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--accent-1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Vous changez de véhicule sans engagement à long terme</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--accent-1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Garantie constructeur active pendant toute la durée</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M20 6L9 17l-5-5" stroke="var(--accent-1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Entretien et assistance souvent inclus au contrat</li>
          </ul>
        </div>
        <div class="pc-card stagger-item">
          <h3>Ce qu'il faut anticiper</h3>
          <ul class="pc-list">
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="var(--text-faint)" stroke-width="2" stroke-linecap="round"/></svg> Vous n'êtes pas propriétaire tant que l'option n'est pas levée</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="var(--text-faint)" stroke-width="2" stroke-linecap="round"/></svg> L'état du véhicule est vérifié à la restitution</li>
            <li><svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M18 6L6 18M6 6l12 12" stroke="var(--text-faint)" stroke-width="2" stroke-linecap="round"/></svg> Le coût total peut dépasser celui d'un achat comptant</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section id="eligibilite" class="section-border">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="section-eyebrow">05 — Éligibilité</div>
        <h2>Suis-je éligible à la LOA ?</h2>
      </div>
      <div class="elig-grid stagger">
        <div class="elig-card stagger-item">
          <h3>Pour les particuliers</h3>
          <ul>
            <li>Être majeur et titulaire d'un permis de conduire valide</li>
            <li>Justifier de revenus réguliers (CDI, indépendant, retraité...)</li>
            <li>Un taux d'endettement raisonnable</li>
            <li>Ne pas avoir d'incident bancaire bloquant</li>
          </ul>
        </div>
        <div class="elig-card stagger-item">
          <h3>Pour les professionnels</h3>
          <ul>
            <li>Une activité établie, documentée</li>
            <li>Des bilans ou un prévisionnel selon l'ancienneté</li>
            <li>Une caution personnelle parfois demandée pour les jeunes structures</li>
          </ul>
        </div>
      </div>
      <div class="inline-cta reveal">
        <p>Le seul moyen de savoir avec certitude : notre test vous donne une réponse indicative en moins de 2 minutes, sans engagement.</p>
        <a href="/simulation" class="btn-primary">Tester mon éligibilité</a>
      </div>
    </div>
  </section>

  <section id="fin-de-contrat" class="section-border">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="section-eyebrow">06 — Et après ?</div>
        <h2>Fin de contrat : trois options.</h2>
      </div>
      <div class="cat-grid stagger">
        <div class="cat-card stagger-item">
          <div class="tag">Option 1</div>
          <h3>Racheter le véhicule</h3>
          <p>Vous payez le prix fixé à la signature et devenez propriétaire. Intéressant si le véhicule vaut plus sur le marché que son prix de rachat.</p>
        </div>
        <div class="cat-card stagger-item">
          <div class="tag">Option 2</div>
          <h3>Restituer le véhicule</h3>
          <p>Vous rendez les clés sans rien payer de plus. Pratique si vos besoins ont évolué. L'état du véhicule est contrôlé au retour.</p>
        </div>
        <div class="cat-card stagger-item">
          <div class="tag">Option 3</div>
          <h3>Repartir sur un nouveau contrat</h3>
          <p>Vous enchaînez directement sur un modèle plus récent — l'option de ceux qui aiment rouler neuf en permanence.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="pourquoi-eleven-auto" class="section-border">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="section-eyebrow">07 — Notre rôle</div>
        <h2>Pourquoi passer par Eleven Lease ?</h2>
      </div>
      <div class="body-text reveal">
        <p>Passer directement par une concession, c'est se limiter à l'organisme financier avec lequel elle travaille — un seul jeu de conditions, sans point de comparaison.</p>
        <p>Eleven Lease met votre dossier en relation avec plusieurs partenaires financiers de notre réseau. Chacun étudie votre profil selon ses propres critères, et nous vous transmettons l'offre la plus adaptée à votre situation.</p>
      </div>
      <div class="why-list stagger">
        <div class="why-item stagger-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="var(--accent-1)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Accès à plusieurs partenaires financiers, pas un seul</span></div>
        <div class="why-item stagger-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="var(--accent-1)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Un seul formulaire, une seule démarche</span></div>
        <div class="why-item stagger-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="var(--accent-1)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Réponse sous 24h en général</span></div>
        <div class="why-item stagger-item"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" stroke="var(--accent-1)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg><span>Un conseiller dédié jusqu'à la livraison</span></div>
      </div>
    </div>
  </section>

  <section id="faq" class="section-border">
    <div class="wrap">
      <div class="section-head reveal">
        <div class="section-eyebrow">08 — En bref</div>
        <h2>Questions fréquentes.</h2>
      </div>
      <div class="faq-list stagger">
        <details class="faq-item stagger-item">
          <summary>Quelle est la différence entre LOA et LLD ?<span class="faq-icon"></span></summary>
          <div class="faq-content"><p>En LOA, un prix de rachat est fixé dès la signature : vous savez depuis le début combien coûterait le véhicule si vous l'achetiez en fin de contrat. En LLD, aucune option d'achat n'est prévue à l'avance — la restitution est la finalité par défaut. C'est surtout ce niveau de flexibilité qui distingue les deux formules.</p></div>
        </details>
        <details class="faq-item stagger-item">
          <summary>Faut-il obligatoirement un apport ?<span class="faq-icon"></span></summary>
          <div class="faq-content"><p>Non. Un apport n'est pas obligatoire, mais il réduit mécaniquement votre loyer mensuel puisqu'il diminue le montant financé. Beaucoup de nos clients démarrent sans apport pour préserver leur trésorerie.</p></div>
        </details>
        <details class="faq-item stagger-item">
          <summary>Puis-je faire une LOA si je suis fiché à la Banque de France ?<span class="faq-icon"></span></summary>
          <div class="faq-content"><p>C'est un critère généralement bloquant chez la plupart des organismes de financement, mais chaque dossier reste étudié au cas par cas. Notre test d'éligibilité vous donne une première indication honnête, y compris dans cette situation.</p></div>
        </details>
        <details class="faq-item stagger-item">
          <summary>Y a-t-il une limite de kilométrage avec Eleven Lease ?<span class="faq-icon"></span></summary>
          <div class="faq-content"><p>Non. Contrairement à une LOA classique où un forfait kilométrique est facturé en cas de dépassement, l'offre de leasing proposée par Eleven Lease est à kilométrage illimité, pour les particuliers comme pour les professionnels : aucun forfait à respecter, aucune régularisation à prévoir en fin de contrat.</p></div>
        </details>
        <details class="faq-item stagger-item">
          <summary>Puis-je changer de véhicule avant la fin du contrat ?<span class="faq-icon"></span></summary>
          <div class="faq-content"><p>C'est possible dans certains cas (rachat anticipé, transfert de contrat), mais les conditions varient selon l'organisme financier. Votre conseiller Eleven Lease étudie la meilleure option selon votre situation.</p></div>
        </details>
        <details class="faq-item stagger-item">
          <summary>Quelle assurance est obligatoire en LOA ?<span class="faq-icon"></span></summary>
          <div class="faq-content"><p>Comme pour tout véhicule, l'assurance au tiers minimum est obligatoire. La plupart des organismes financiers exigent en plus une garantie tous risques pendant toute la durée du contrat, le véhicule ne vous appartenant pas encore.</p></div>
        </details>
        <details class="faq-item stagger-item">
          <summary>La LOA est-elle adaptée aux véhicules électriques ?<span class="faq-icon"></span></summary>
          <div class="faq-content"><p>Oui, et c'est même une formule particulièrement adaptée : elle permet de profiter des dernières avancées technologiques (autonomie, recharge) sans supporter la décote liée à l'évolution rapide de cette motorisation.</p></div>
        </details>
        <details class="faq-item stagger-item">
          <summary>Combien de temps pour obtenir une réponse ?<span class="faq-icon"></span></summary>
          <div class="faq-content"><p>Comptez généralement 24 à 48h après réception d'un dossier complet. La simulation elle-même est instantanée et ne vous engage à rien.</p></div>
        </details>
      </div>
    </div>
  </section>

  <section class="section-border">
    <div class="wrap">
      <div class="cta-band reveal">
        <h2>Prêt à passer à l'action ?</h2>
        <p>Décrivez votre projet, on s'occupe de trouver la bonne offre.</p>
        <a href="/simulation" class="btn-primary">Simuler mon leasing</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  section[id]{scroll-margin-top:90px;}
  section{padding:96px 0;}
  @media(max-width:768px){ section{padding:64px 0;} }
  #fonctionnement{background:var(--surface);}
  #pourquoi-eleven-auto{background:var(--surface);}

  /* page hero */
  .page-hero{padding:150px 0 64px;border-bottom:1px solid var(--border);}
  .eyebrow{
    display:inline-flex;align-items:center;gap:8px;font-size:13px;color:var(--text-dim);
    border:1px solid var(--border);padding:6px 14px;border-radius:100px;margin-bottom:24px;width:fit-content;
  }
  .eyebrow .dot{width:6px;height:6px;border-radius:50%;background:var(--accent-1);}
  .page-hero h1{font-size:clamp(34px,5.5vw,58px);max-width:760px;}
  .page-hero p{color:var(--text-dim);font-size:17px;margin-top:20px;max-width:600px;}
  .hero-actions{display:flex;gap:16px;margin-top:36px;flex-wrap:wrap;}
  @keyframes heroIn{ from{opacity:0;transform:translateY(20px);} to{opacity:1;transform:translateY(0);} }
  .page-hero .eyebrow{animation:heroIn .7s cubic-bezier(.16,1,.3,1) both;}
  .page-hero h1{animation:heroIn .7s cubic-bezier(.16,1,.3,1) .08s both;}
  .page-hero > .wrap > p{animation:heroIn .7s cubic-bezier(.16,1,.3,1) .16s both;}
  .page-hero .hero-actions{animation:heroIn .7s cubic-bezier(.16,1,.3,1) .24s both;}
  .btn-primary{
    background:var(--accent);color:#fff;padding:15px 26px;border-radius:100px;
    font-weight:600;font-size:14.5px;display:inline-block;
    transition:transform .2s ease, filter .2s ease, box-shadow .3s ease;
  }
  .btn-primary:hover{filter:brightness(1.12);transform:translateY(-2px);box-shadow:0 14px 32px rgba(255,0,127,0.22), 0 4px 10px rgba(255,0,127,0.16);}
  .btn-primary:active{transform:scale(.96);box-shadow:0 4px 12px rgba(255,0,127,0.2);}
  .btn-ghost{
    border:1px solid var(--border);padding:15px 26px;border-radius:100px;
    font-weight:600;font-size:14.5px;color:var(--text);
    transition:border-color .2s ease, transform .2s ease, color .2s ease;display:inline-block;
  }
  .btn-ghost:hover{border-color:var(--accent-1);color:var(--accent-1);transform:translateY(-2px);}
  .btn-ghost:active{transform:scale(.96);}

  /* table of contents */
  .toc-card{border:1px solid var(--border);border-radius:20px;padding:36px;background:#fff;box-shadow:var(--shadow-sm);margin-top:56px;}
  .toc-title{font-size:12px;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:20px;}
  .toc-list{display:grid;grid-template-columns:1fr 1fr;gap:14px 32px;list-style:none;}
  .toc-list li{counter-increment:toc;}
  .toc-list{counter-reset:toc;}
  .toc-list a{font-size:15px;color:var(--text-dim);display:flex;gap:10px;transition:color .25s ease, transform .25s cubic-bezier(.16,1,.3,1);}
  .toc-list a::before{content:counter(toc, decimal-leading-zero);color:var(--text-faint);font-family:'Space Grotesk',sans-serif;font-size:13px;transition:color .25s ease;}
  .toc-list a:hover{color:var(--text);transform:translateX(4px);}
  .toc-list a:hover::before{color:var(--text-dim);}
  @media(max-width:640px){ .toc-list{grid-template-columns:1fr;} }

  /* section headers */
  .section-head{margin-bottom:44px;max-width:680px;}
  .section-eyebrow{font-size:13px;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:14px;}
  .section-head h2{font-size:clamp(26px,3.6vw,38px);}
  .section-head p{color:var(--text-dim);font-size:16px;margin-top:14px;}
  .section-border{border-top:1px solid var(--border);}
  .body-text{color:var(--text-dim);font-size:16px;line-height:1.75;max-width:760px;}
  .body-text p + p{margin-top:18px;}

  /* steps (comment ça marche) */
  .steps{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);border-radius:20px;overflow:hidden;}
  .step{position:relative;background:var(--bg);padding:32px 26px;overflow:hidden;transition:background .5s cubic-bezier(.16,1,.3,1);}
  .step::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at 25% 15%, rgba(17,17,19,.03), transparent 65%);opacity:0;transition:opacity .5s cubic-bezier(.16,1,.3,1);pointer-events:none;}
  .step:hover{background:var(--surface);}
  .step:hover::after{opacity:1;}
  .step .num{font-family:'Space Grotesk',sans-serif;font-size:13px;color:var(--text-faint);margin-bottom:22px;transition:color .4s ease, transform .4s cubic-bezier(.16,1,.3,1);}
  .step h3{font-size:18px;margin-bottom:10px;transition:transform .4s cubic-bezier(.16,1,.3,1);}
  .step p{font-size:14px;color:var(--text-dim);transition:transform .4s cubic-bezier(.16,1,.3,1);}
  .step:hover .num{color:var(--text-dim);transform:translateX(2px);}
  .step:hover h3{transform:translateX(4px);}
  .step:hover p{transform:translateX(4px);}
  @media(max-width:900px){ .steps{grid-template-columns:1fr 1fr;} }
  @media(max-width:560px){ .steps{grid-template-columns:1fr;} }

  /* cost levers */
  .cost-levers{display:grid;grid-template-columns:repeat(2,1fr);gap:14px;margin:32px 0 36px;}
  @media(max-width:640px){ .cost-levers{grid-template-columns:1fr;} }
  .cost-lever{position:relative;background:#fff;border:1px solid var(--border);border-radius:14px;padding:20px 22px;overflow:hidden;box-shadow:var(--shadow-sm);transition:border-color .5s cubic-bezier(.16,1,.3,1), transform .5s cubic-bezier(.16,1,.3,1), box-shadow .5s cubic-bezier(.16,1,.3,1);}
  .cost-lever::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at 25% 15%, rgba(17,17,19,.03), transparent 65%);opacity:0;transition:opacity .5s cubic-bezier(.16,1,.3,1);pointer-events:none;}
  .cost-lever:hover{border-color:#d8d8dd;transform:translateY(-4px);box-shadow:var(--shadow-md);}
  .cost-lever:hover::after{opacity:1;}
  .cost-lever strong{display:block;color:var(--text);font-size:15px;margin-bottom:5px;transition:transform .4s cubic-bezier(.16,1,.3,1);}
  .cost-lever span{font-size:13.5px;color:var(--text-dim);transition:transform .4s cubic-bezier(.16,1,.3,1);}
  .cost-lever:hover strong{transform:translateX(3px);}
  .cost-lever:hover span{transform:translateX(3px);}
  .example-box{
    border:1px solid var(--border);border-radius:18px;padding:30px 32px;
    background:radial-gradient(ellipse at 50% 0%, var(--surface), var(--bg));
    max-width:760px;
  }
  .example-box p{color:var(--text-dim);font-size:15px;line-height:1.75;}
  .example-box a{color:var(--text);font-weight:600;text-decoration:underline;text-underline-offset:3px;}
  .indicative-note{font-size:12.5px;color:var(--text-faint);margin-top:16px;}

  /* pros / cons */
  .pros-cons{display:grid;grid-template-columns:1fr 1fr;gap:20px;}
  @media(max-width:768px){ .pros-cons{grid-template-columns:1fr;} }
  .pc-card{background:#fff;border:1px solid var(--border);border-radius:18px;padding:32px;box-shadow:var(--shadow-sm);transition:border-color .25s ease, box-shadow .25s ease;}
  .pc-card:hover{border-color:#d8d8dd;box-shadow:var(--shadow-md);}
  .pc-card h3{font-size:17px;margin-bottom:20px;display:flex;align-items:center;gap:10px;}
  .pc-list{display:flex;flex-direction:column;gap:14px;list-style:none;}
  .pc-list li{display:flex;gap:10px;font-size:14.5px;color:var(--text-dim);align-items:flex-start;line-height:1.5;transition:color .2s ease;}
  .pc-list li:hover{color:var(--text);}
  .pc-list svg{flex:none;margin-top:3px;transition:transform .25s cubic-bezier(.16,1,.3,1);}
  .pc-list li:hover svg{transform:scale(1.15);}

  /* eligibility */
  .elig-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:32px;}
  @media(max-width:768px){ .elig-grid{grid-template-columns:1fr;} }
  .elig-card{background:#fff;border:1px solid var(--border);border-radius:18px;padding:30px;box-shadow:var(--shadow-sm);transition:border-color .25s ease, transform .25s cubic-bezier(.16,1,.3,1), box-shadow .25s ease;}
  .elig-card:hover{border-color:#d8d8dd;transform:translateY(-3px);box-shadow:var(--shadow-md);}
  .elig-card h3{font-size:16px;margin-bottom:16px;}
  .elig-card ul{list-style:none;display:flex;flex-direction:column;gap:11px;}
  .elig-card li{font-size:14.5px;color:var(--text-dim);padding-left:18px;position:relative;}
  .elig-card li::before{content:'';position:absolute;left:0;top:8px;width:5px;height:5px;border-radius:50%;background:var(--text-faint);}
  .inline-cta{
    display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;
    padding:28px 32px;border:1px solid var(--border);border-radius:24px;background:#fff;box-shadow:var(--shadow-sm);
    max-width:760px;
  }
  .inline-cta p{font-size:14.5px;color:var(--text-dim);max-width:480px;}

  /* end of contract cards */
  .cat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
  @media(max-width:900px){ .cat-grid{grid-template-columns:1fr;} }
  .cat-card{
    background:#fff;border:1px solid var(--border);border-radius:18px;padding:30px;box-shadow:var(--shadow-sm);
    transition:border-color .25s ease, transform .3s cubic-bezier(.16,1,.3,1), box-shadow .3s ease;
  }
  .cat-card:hover{border-color:#d8d8dd;transform:translateY(-4px);box-shadow:var(--shadow-md);}
  .cat-card .tag{font-size:12px;color:var(--text-faint);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:16px;}
  .cat-card h3{font-size:19px;margin-bottom:10px;}
  .cat-card p{color:var(--text-dim);font-size:14px;}

  /* why eleven auto */
  .why-list{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:28px;}
  @media(max-width:640px){ .why-list{grid-template-columns:1fr;} }
  .why-item{display:flex;gap:12px;align-items:flex-start;padding:18px 0;border-top:1px solid var(--border);transition:padding-left .25s cubic-bezier(.16,1,.3,1);}
  .why-item:hover{padding-left:6px;}
  .why-item svg{flex:none;margin-top:2px;transition:transform .3s cubic-bezier(.16,1,.3,1);}
  .why-item:hover svg{transform:scale(1.15) rotate(-4deg);}
  .why-item span{font-size:14.5px;color:var(--text-dim);transition:color .25s ease;}
  .why-item:hover span{color:var(--text);}

  /* faq */
  .faq-list{max-width:820px;}
  .faq-item{border-bottom:1px solid var(--border);padding:22px 0;}
  .faq-item summary{
    cursor:pointer;font-size:16px;font-weight:600;list-style:none;
    display:flex;justify-content:space-between;align-items:center;gap:16px;
    transition:color .25s ease;
  }
  .faq-item summary::-webkit-details-marker{display:none;}
  .faq-item:hover summary{color:var(--text);}
  .faq-icon{position:relative;width:16px;height:16px;flex:none;}
  .faq-icon::before,.faq-icon::after{
    content:'';position:absolute;top:50%;left:50%;background:var(--text-faint);
    transition:transform .35s cubic-bezier(.16,1,.3,1), background .25s ease;
  }
  .faq-icon::before{width:14px;height:1.5px;transform:translate(-50%,-50%);}
  .faq-icon::after{width:1.5px;height:14px;transform:translate(-50%,-50%);}
  .faq-item[open] .faq-icon::after{transform:translate(-50%,-50%) rotate(90deg);}
  .faq-item[open] .faq-icon::before,
  .faq-item[open] .faq-icon::after{background:var(--accent-1);}
  .faq-content{overflow:hidden;}
  .faq-content p{color:var(--text-dim);font-size:14.5px;line-height:1.75;padding-top:14px;max-width:700px;}

  /* cta band */
  .cta-band{
    border:1px solid var(--border);border-radius:24px;padding:64px 48px;text-align:center;
    background:radial-gradient(ellipse at 50% 0%, var(--surface), var(--bg));
  }
  .cta-band h2{font-size:clamp(26px,3.5vw,38px);margin-bottom:14px;}
  .cta-band p{color:var(--text-dim);margin-bottom:28px;}
  @media(max-width:640px){ .cta-band{padding:40px 24px;} }

  .reveal{opacity:0;transform:translateY(24px) scale(.985);transition:opacity .7s cubic-bezier(.16,1,.3,1), transform .7s cubic-bezier(.16,1,.3,1);}
  .reveal.visible{opacity:1;transform:translateY(0) scale(1);}

  /* staggered grid reveal */
  .stagger-item{opacity:0;transform:translateY(16px) scale(.985);transition:opacity .6s cubic-bezier(.16,1,.3,1), transform .6s cubic-bezier(.16,1,.3,1);}
  .stagger.visible .stagger-item{opacity:1;transform:translateY(0) scale(1);}
  .stagger.visible .stagger-item:nth-child(1){transition-delay:.02s;}
  .stagger.visible .stagger-item:nth-child(2){transition-delay:.09s;}
  .stagger.visible .stagger-item:nth-child(3){transition-delay:.16s;}
  .stagger.visible .stagger-item:nth-child(4){transition-delay:.23s;}
  .stagger.visible .stagger-item:nth-child(5){transition-delay:.30s;}
  .stagger.visible .stagger-item:nth-child(6){transition-delay:.37s;}
  .stagger.visible .stagger-item:nth-child(7){transition-delay:.44s;}
  .stagger.visible .stagger-item:nth-child(8){transition-delay:.51s;}
</style>

<script>
  // scroll reveal
  const items = document.querySelectorAll('.reveal, .stagger');
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('visible'); io.unobserve(e.target); } });
  },{threshold:0.12});
  items.forEach(i=>io.observe(i));

  // magnetic buttons (desktop only)
  const isTouch = window.matchMedia('(pointer: coarse)').matches;
  if(!isTouch){
    document.querySelectorAll<HTMLElement>('.btn-primary, .btn-ghost').forEach(btn=>{
      btn.addEventListener('mousemove', (e: MouseEvent)=>{
        const r = btn.getBoundingClientRect();
        const x = e.clientX - r.left - r.width/2;
        const y = e.clientY - r.top - r.height/2;
        btn.style.transform = `translate(${x*0.18}px, ${y*0.35}px)`;
      });
      btn.addEventListener('mouseleave', ()=>{ btn.style.transform = 'translate(0,0)'; });
    });
  }

  // faq accordion — smooth height/opacity animation on open & close
  const faqEasing = 'cubic-bezier(.16,1,.3,1)';
  document.querySelectorAll<HTMLDetailsElement>('.faq-item').forEach(item=>{
    const summary = item.querySelector('summary')!;
    const content = item.querySelector<HTMLElement>('.faq-content')!;
    summary.addEventListener('click', (e)=>{
      e.preventDefault();
      if(item.classList.contains('is-animating')) return;
      item.open ? closeFaq(item, content) : openFaq(item, content);
    });
  });

  function openFaq(item: HTMLDetailsElement, content: HTMLElement){
    item.classList.add('is-animating');
    item.open = true;
    const target = content.scrollHeight;
    content.style.overflow = 'hidden';
    const anim = content.animate(
      [{ height:'0px', opacity:0 }, { height: target+'px', opacity:1 }],
      { duration:320, easing:faqEasing }
    );
    anim.onfinish = ()=>{
      content.style.overflow = '';
      content.style.height = '';
      item.classList.remove('is-animating');
    };
  }

  function closeFaq(item: HTMLDetailsElement, content: HTMLElement){
    item.classList.add('is-animating');
    const start = content.scrollHeight;
    content.style.overflow = 'hidden';
    const anim = content.animate(
      [{ height:start+'px', opacity:1 }, { height:'0px', opacity:0 }],
      { duration:280, easing:faqEasing }
    );
    anim.onfinish = ()=>{
      item.open = false;
      content.style.overflow = '';
      content.style.height = '';
      item.classList.remove('is-animating');
    };
  }
</script>
