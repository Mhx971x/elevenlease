---
import MinimalLayout from '../layouts/MinimalLayout.astro';
---
<MinimalLayout
  title="Eleven Lease — Tous nos liens"
  description="Retrouvez tous les liens Eleven Lease : simulez votre leasing, discutez sur WhatsApp, suivez-nous sur Instagram et TikTok."
  path="/bio"
>
  <div class="page">
    <div class="bg-grid"></div>
    <canvas class="bg-stars" id="bgStars"></canvas>

    <div class="card">
      <div class="avatar">
        <img src="/Avatar.jpg" alt="Eleven Lease">
      </div>
      <h1 class="name">Eleven Lease</h1>
      <p class="tagline">Le bon leasing, trouvé pour vous. Simulez votre projet ou discutez avec nous directement.</p>

      <div class="links">
        <a class="link-btn primary" href="/simulation">
          <span class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          Simuler mon leasing
          <span class="arrow">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>

        <a class="link-btn whatsapp" href="https://taap.it/elevenleasewhatsapp" target="_blank" rel="noopener">
          <span class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.6 6.32A8.86 8.86 0 0012.05 4c-4.9 0-8.9 4-8.9 8.9 0 1.57.42 3.1 1.2 4.44L3 22l4.8-1.26a8.9 8.9 0 004.25 1.08h0c4.9 0 8.9-4 8.9-8.9 0-2.38-.93-4.62-2.35-6.6zm-5.55 13.7h0a7.4 7.4 0 01-3.77-1.03l-.27-.16-2.8.74.75-2.73-.18-.28a7.38 7.38 0 01-1.13-3.94c0-4.08 3.32-7.4 7.4-7.4 1.98 0 3.84.77 5.24 2.17a7.35 7.35 0 012.16 5.23c0 4.08-3.32 7.4-7.4 7.4zm4.06-5.54c-.22-.11-1.31-.65-1.52-.72-.2-.08-.35-.11-.5.11-.15.22-.57.72-.7.87-.13.15-.26.16-.48.05-.22-.11-.94-.35-1.79-1.1-.66-.6-1.1-1.33-1.24-1.55-.13-.22-.01-.34.1-.45.1-.1.22-.26.33-.39.11-.13.15-.22.22-.37.07-.15.04-.28-.02-.39-.06-.11-.5-1.21-.69-1.66-.18-.43-.36-.38-.5-.38h-.43c-.15 0-.39.05-.59.28-.2.22-.78.76-.78 1.86s.8 2.16.91 2.31c.11.15 1.57 2.4 3.81 3.36.53.23.95.37 1.27.47.53.17 1.02.15 1.4.09.43-.06 1.31-.53 1.49-1.05.18-.51.18-.95.13-1.05-.05-.1-.2-.16-.42-.27z"/></svg>
          </span>
          Discuter sur WhatsApp
          <span class="arrow">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>

        <a class="link-btn" href="/vehicules">
          <span class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M3 13l1.5-5A2 2 0 016.4 6.5h11.2a2 2 0 011.9 1.5L21 13M3 13v5a1 1 0 001 1h1a1 1 0 001-1v-1h12v1a1 1 0 001 1h1a1 1 0 001-1v-5M3 13h18" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><circle cx="7.5" cy="17" r="1.3" fill="currentColor"/><circle cx="16.5" cy="17" r="1.3" fill="currentColor"/></svg>
          </span>
          Voir les véhicules disponibles
          <span class="arrow">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>

        <a class="link-btn" href="/loa">
          <span class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M4 19.5A2.5 2.5 0 016.5 17H20M4 19.5A2.5 2.5 0 006.5 22H20V4H6.5A2.5 2.5 0 004 6.5v13z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          Le guide LOA : tout comprendre
          <span class="arrow">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>

        <a class="link-btn" href="/">
          <span class="icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.6"/><path d="M3 12h18M12 3c2.5 2.7 3.8 6 3.8 9s-1.3 6.3-3.8 9c-2.5-2.7-3.8-6-3.8-9s1.3-6.3 3.8-9z" stroke="currentColor" stroke-width="1.6"/></svg>
          </span>
          Voir le site complet
          <span class="arrow">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
        </a>
      </div>

      <div class="socials">
        <a class="social-btn" href="https://www.instagram.com/elevenlease" target="_blank" rel="noopener" aria-label="Instagram">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="none"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.7"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.7"/><circle cx="17.3" cy="6.7" r="1.1" fill="currentColor"/></svg>
        </a>
        <a class="social-btn" href="https://www.tiktok.com/@elevenlease" target="_blank" rel="noopener" aria-label="TikTok">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16.6 5.82a4.28 4.28 0 01-2.66-1.28A4.53 4.53 0 0112.9 2H10.1v13.6a2.6 2.6 0 11-2.1-2.55V10.3a5.4 5.4 0 105.1 5.38V9.4a7 7 0 003.5 1.02V7.6a4.3 4.3 0 01-.9-.18v.02c-1.34-.42-.09 0 0 0z"/></svg>
        </a>
      </div>

      <p class="foot-note">© 2026 Eleven Lease · <a href="/mentions-legales">Mentions légales</a></p>
    </div>
  </div>
</MinimalLayout>

<style>
  body{
    background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;line-height:1.5;
    min-height:100vh;display:flex;justify-content:center;
    -webkit-font-smoothing:antialiased;
  }
  h1{font-family:'Space Grotesk',sans-serif;font-weight:700;letter-spacing:-0.02em;}

  .page{position:relative;width:100%;min-height:100vh;overflow:hidden;display:flex;justify-content:center;}
  .bg-grid{
    position:absolute;inset:0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size:56px 56px;
    mask-image:radial-gradient(ellipse 70% 55% at 50% 25%, black, transparent);
    opacity:0.5;
  }
  .bg-stars{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:0;mask-image:radial-gradient(ellipse 65% 55% at 50% 22%, black, transparent);}

  .card{
    position:relative;z-index:2;width:100%;max-width:440px;
    padding:56px 24px 40px;display:flex;flex-direction:column;align-items:center;
  }

  .avatar{
    width:84px;height:84px;border-radius:24px;background:var(--bg);
    border:1px solid var(--border);
    display:flex;align-items:center;justify-content:center;margin-bottom:22px;
    animation:fadeUp .6s cubic-bezier(.16,1,.3,1) both;
    box-shadow:0 10px 40px rgba(255,0,127,0.12);
    overflow:hidden;
  }
  .avatar img{width:100%;height:100%;object-fit:cover;border-radius:23px;}

  .name{font-size:22px;margin-bottom:6px;animation:fadeUp .6s cubic-bezier(.16,1,.3,1) .05s both;}
  .tagline{color:var(--text-dim);font-size:14.5px;text-align:center;max-width:300px;margin-bottom:32px;animation:fadeUp .6s cubic-bezier(.16,1,.3,1) .1s both;}

  @keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}

  .links{width:100%;display:flex;flex-direction:column;gap:12px;}
  .link-btn{
    display:flex;align-items:center;gap:14px;width:100%;
    padding:16px 20px;border-radius:16px;border:1px solid var(--border);
    background:var(--surface);font-size:15px;font-weight:600;color:var(--text);
    box-shadow:var(--shadow-sm);
    transition:border-color .2s ease, transform .2s ease, background .2s ease, box-shadow .3s ease;
    opacity:0;transform:translateY(14px);animation:fadeUp .55s cubic-bezier(.16,1,.3,1) forwards;
  }
  .link-btn:nth-child(1){animation-delay:.16s;}
  .link-btn:nth-child(2){animation-delay:.21s;}
  .link-btn:nth-child(3){animation-delay:.26s;}
  .link-btn:nth-child(4){animation-delay:.31s;}
  .link-btn:nth-child(5){animation-delay:.36s;}
  .link-btn:hover{border-color:#d8d8dd;transform:translateY(-2px);background:#fff;box-shadow:var(--shadow-md);}
  .link-btn:active{transform:scale(.98);}
  .link-btn .icon{
    width:38px;height:38px;border-radius:11px;background:var(--surface-2);flex:none;
    display:flex;align-items:center;justify-content:center;color:var(--text-dim);
    transition:background .2s ease, color .2s ease;
  }
  .link-btn:hover .icon{color:var(--text);}
  .link-btn .arrow{margin-left:auto;color:var(--text-faint);transition:transform .2s ease;flex:none;}
  .link-btn:hover .arrow{transform:translateX(3px);color:var(--text-dim);}

  .link-btn.primary{
    background:var(--accent);border-color:transparent;
  }
  .link-btn.primary .icon{background:rgba(255,255,255,0.16);color:#fff;}
  .link-btn.primary:hover{
    transform:translateY(-2px);
    box-shadow:0 14px 32px rgba(255,0,127,0.22), 0 4px 10px rgba(255,0,127,0.16);
    background:var(--accent);
  }
  .link-btn.primary .arrow{color:rgba(255,255,255,0.7);}
  .link-btn.primary:hover .arrow{color:#fff;}

  .link-btn.whatsapp .icon{color:#25D366;}
  .link-btn.whatsapp:hover .icon{color:#25D366;}

  .socials{display:flex;gap:14px;margin-top:32px;opacity:0;animation:fadeUp .55s cubic-bezier(.16,1,.3,1) .44s forwards;}
  .social-btn{
    width:44px;height:44px;border-radius:50%;border:1px solid var(--border);
    display:flex;align-items:center;justify-content:center;color:var(--text-dim);
    transition:border-color .2s ease, color .2s ease, transform .2s ease;
  }
  .social-btn:hover{border-color:var(--accent-1);color:var(--accent-1);transform:translateY(-2px);}

  .foot-note{margin-top:36px;color:var(--text-faint);font-size:12px;text-align:center;opacity:0;animation:fadeUp .55s cubic-bezier(.16,1,.3,1) .5s forwards;}
  .foot-note a{text-decoration:underline;text-underline-offset:2px;}
  .foot-note a:hover{color:var(--text-dim);}

  @media(prefers-reduced-motion:reduce){
    .avatar, .name, .tagline, .link-btn, .socials, .foot-note{animation:none;opacity:1;transform:none;}
  }
</style>

<script>
  // fond particules — même moteur que heroStars sur la home, recoloré thème clair (graphite discret + touche rose)
  (function(){
    const canvas = document.getElementById('bgStars') as HTMLCanvasElement | null;
    if(!canvas) return;
    const ctx = canvas.getContext('2d');
    if(!ctx) return;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const isTouch = window.matchMedia('(pointer: coarse)').matches;
    const rand = (min: number, max: number) => Math.random()*(max-min)+min;

    let W: number, H: number, DPR: number;
    let particles: any[] = [];
    let mouseX = 0.5, mouseY = 0.5, targetX = 0.5, targetY = 0.5;
    let rafId: number, lastT = 0, running = false;

    function makeParticle(fromTop: boolean){
      const depth = Math.random();
      return {
        x: rand(0, W),
        y: fromTop ? -10 : rand(0, H),
        r: rand(0.5,1.1) + depth*1.4,
        depth,
        vy: rand(4,8) + depth*9,
        driftAmp: rand(6,14) + depth*8,
        driftFreq: rand(0.15,0.35),
        phase: rand(0, Math.PI*2),
        twinkleFreq: rand(0.4,1.2),
        twinklePhase: rand(0, Math.PI*2),
        baseAlpha: rand(0.08,0.16) + depth*0.08,
        pink: Math.random() < 0.1,
      };
    }

    function seed(){
      const area = W*H;
      const target = Math.max(20, Math.min(50, Math.round(area/9000)));
      particles = Array.from({length: target}, () => makeParticle(false));
    }

    function resize(){
      W = window.innerWidth; H = window.innerHeight;
      DPR = Math.min(window.devicePixelRatio || 1, 2);
      canvas!.width = W*DPR; canvas!.height = H*DPR;
      canvas!.style.width = W+'px'; canvas!.style.height = H+'px';
      ctx!.setTransform(DPR,0,0,DPR,0,0);
      seed();
      drawStatic();
    }

    function drawStatic(){
      ctx!.clearRect(0,0,W,H);
      for(const p of particles){
        ctx!.beginPath();
        ctx!.fillStyle = p.pink ? `rgba(255,0,127,${p.baseAlpha})` : `rgba(17,17,19,${p.baseAlpha})`;
        ctx!.arc(p.x,p.y,p.r,0,Math.PI*2);
        ctx!.fill();
      }
    }

    function frame(t: number){
      if(!running) return;
      const dt = Math.min((t-lastT)/1000, 0.05);
      lastT = t;
      mouseX += (targetX-mouseX)*0.04;
      mouseY += (targetY-mouseY)*0.04;
      const time = t/1000;
      const parX = (mouseX-0.5)*16;
      const parY = (mouseY-0.5)*10;

      ctx!.clearRect(0,0,W,H);
      for(const p of particles){
        p.y += p.vy*dt;
        if(p.y - p.r > H+20) Object.assign(p, makeParticle(true));
        const driftX = Math.sin(time*p.driftFreq + p.phase)*p.driftAmp;
        const twinkle = 0.55 + 0.45*Math.sin(time*p.twinkleFreq + p.twinklePhase);
        const alpha = p.baseAlpha*twinkle;
        const px = p.x + driftX + parX*p.depth;
        const py = p.y + parY*p.depth;
        ctx!.beginPath();
        ctx!.fillStyle = p.pink ? `rgba(255,0,127,${alpha})` : `rgba(17,17,19,${alpha})`;
        ctx!.arc(px,py,p.r,0,Math.PI*2);
        ctx!.fill();
      }

      rafId = requestAnimationFrame(frame);
    }

    if(!isTouch){
      window.addEventListener('mousemove', (e: MouseEvent)=>{
        targetX = e.clientX/W;
        targetY = e.clientY/H;
      });
    }

    document.addEventListener('visibilitychange', ()=>{
      if(reduceMotion) return;
      if(document.hidden){ running = false; cancelAnimationFrame(rafId); }
      else if(!running){ running = true; lastT = performance.now(); rafId = requestAnimationFrame(frame); }
    });

    window.addEventListener('resize', resize);
    resize();

    if(!reduceMotion){
      running = true;
      lastT = performance.now();
      rafId = requestAnimationFrame(frame);
    }
  })();
</script>
